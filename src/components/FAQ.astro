---
import { siteConfig as defaultConfig } from '../config.ts';
import { Icon } from 'astro-icon/components';
import { faqItems as defaultFaqItems } from '../content/faq';

const { config = defaultConfig, items = defaultFaqItems } = Astro.props;
---

<section id="faq" class="relative bg-white section-lg px-4 sm:px-6 lg:px-8">
  <div class="mx-auto max-w-4xl">
    <div class="scroll-fade-up mb-12 text-center">
      <h2 class="text-mono-heading mb-4 text-2xl font-medium sm:text-3xl lg:text-4xl">
        {config.faq.title}
      </h2>
      <p class="text-mono-dark text-base sm:text-lg">
        {config.faq.subtitle}
      </p>
    </div>

    <div class="space-y-4">
      {
        items.map((item, index) => (
          <div
            class={`scroll-fade-up border-mono-lighter rounded-lg border transition-shadow duration-200 hover:shadow-md stagger-${(index % 9) + 1}`}
          >
            <button
              class="faq-button flex w-full cursor-pointer items-center justify-between px-6 py-5 text-left transition-colors duration-200 hover:bg-mono-lighter/50"
              aria-expanded="false"
            >
              <span class="text-mono-heading pr-8 font-semibold">
                {item.question}
              </span>
              <Icon
                name="heroicons:chevron-down"
                class="faq-icon text-mono-gray h-5 w-5 flex-shrink-0"
              />
            </button>
            <div class="faq-content text-mono-dark px-6 leading-relaxed">
              {item.answer}
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const faqButtons = document.querySelectorAll('.faq-button');
    faqButtons.forEach((button) => {
      button.addEventListener('click', () => {
        const content = button.nextElementSibling;
        const isExpanded = button.getAttribute('aria-expanded') === 'true';
        button.setAttribute('aria-expanded', String(!isExpanded));
        content?.classList.toggle('active');
      });
    });
  });
</script>
