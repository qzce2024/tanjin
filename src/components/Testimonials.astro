---
import { siteConfig as defaultConfig } from '../config.ts';
import { Icon } from 'astro-icon/components';
import { testimonialsData as defaultTestimonials } from '../content/testimonials';

const { config = defaultConfig, testimonials = defaultTestimonials } = Astro.props;
---

<section class="relative bg-mono-lighter section-lg px-4 sm:px-6 lg:px-8">
  <div class="mx-auto max-w-7xl">
    <div class="scroll-fade-up mx-auto mb-12 max-w-3xl text-center">
      <h2 class="text-mono-heading mb-4 text-2xl font-medium sm:text-3xl lg:text-4xl">
        {config.testimonials.title}
      </h2>
      <p class="text-mono-dark text-base sm:text-lg">
        {config.testimonials.subtitle}
      </p>
    </div>

    <div class="grid grid-cols-1 gap-6 md:grid-cols-3">
      {
        testimonials.map((t, index) => (
          <div
            class={`scroll-fade-up card-hover border-mono-black rounded-xl border-l-4 bg-white p-6 stagger-${(index % 9) + 1}`}
          >
            <div class="mb-3 flex">
              {Array.from({ length: t.rating }).map(() => (
                <Icon name="heroicons:star-solid" class="text-mono-black h-4 w-4" />
              ))}
            </div>
            <p class="text-mono-dark mb-4 text-sm leading-relaxed">"{t.quote}"</p>
            <div class="flex items-center gap-3">
              <div
                class="bg-mono-black flex h-10 w-10 items-center justify-center rounded-full text-xs font-semibold text-white"
              >
                {t.initials}
              </div>
              <div>
                <div class="text-mono-heading text-sm font-semibold">{t.author}</div>
                <div class="text-mono-gray text-xs">{t.role}, {t.company}</div>
              </div>
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>
