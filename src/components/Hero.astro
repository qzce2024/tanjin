---
import { siteConfig as defaultConfig } from '../config.ts';

const { config = defaultConfig, heroImage } = Astro.props;
const hasImage = !!heroImage;
---

<section
  class="mono-mesh to-mono-lighter relative bg-gradient-to-b from-white px-4 pt-32 pb-20 sm:px-6 lg:px-8"
>
  <div class="bg-mono-black absolute top-32 left-0 h-32 w-1"></div>
  <div class="bg-mono-black absolute top-32 right-0 h-32 w-1"></div>

  <div class="mx-auto max-w-7xl">
    {hasImage ? (
      <!-- 左文右图布局 -->
      <div class="grid grid-cols-1 items-center gap-12 lg:grid-cols-2">
        <div>
          <h1
            class="text-mono-heading scroll-fade-up mb-6 text-3xl leading-tight font-extrabold sm:text-4xl lg:text-5xl"
          >
            {config.hero.headline}<br />
            <span class="text-mono-black">{config.hero.subheadline}</span>
          </h1>
          <p
            class="text-mono-dark scroll-fade-up mb-10 text-base leading-relaxed sm:text-lg lg:text-xl"
          >
            {config.hero.description}
          </p>
          <div
            class="scroll-fade-up mb-12 flex flex-col gap-4 sm:flex-row"
          >
            {config.hero.cta.primary.href === '#inquiry' ? (
              <button
                class="inquiry-trigger bg-mono-black rounded-lg px-8 py-4 text-center font-semibold text-white shadow-lg"
              >
                {config.hero.cta.primary.text}
              </button>
            ) : (
              <a
                href={config.hero.cta.primary.href}
                class="bg-mono-black rounded-lg px-8 py-4 text-center font-semibold text-white shadow-lg"
              >
                {config.hero.cta.primary.text}
              </a>
            )}
            <a
              href={config.hero.cta.secondary.href}
              class="border-mono-black text-mono-black rounded-lg border-2 bg-white px-8 py-4 text-center font-semibold"
            >
              {config.hero.cta.secondary.text}
            </a>
          </div>

          <div
            class="border-mono-lighter grid grid-cols-3 gap-8 border-t pt-8"
          >
            {config.hero.stats.map((stat, index) => (
              <div class={`float scroll-fade-up stagger-${index + 1}`}>
                <div class="text-mono-black mb-2 text-2xl font-bold sm:text-3xl">
                  {stat.value}
                </div>
                <div class="text-mono-gray text-sm tracking-wide uppercase">
                  {stat.label}
                </div>
              </div>
            ))}
          </div>
        </div>

        <div class="scroll-fade-right flex items-center justify-center">
          <img
            src={heroImage}
            alt={config.hero.headline}
            class="w-full max-w-lg rounded-2xl shadow-2xl"
          />
        </div>
      </div>
    ) : (
      <!-- 居中布局（默认） -->
      <div class="mx-auto max-w-4xl text-center">
        <h1
          class="text-mono-heading scroll-fade-up mb-6 text-5xl leading-tight font-extrabold sm:text-6xl lg:text-7xl"
        >
          {config.hero.headline}<br />
          <span class="text-mono-black">{config.hero.subheadline}</span>
        </h1>
        <p
          class="text-mono-dark scroll-fade-up mb-10 text-xl leading-relaxed sm:text-2xl"
        >
          {config.hero.description}
        </p>
        <div
          class="scroll-fade-up mb-16 flex flex-col justify-center gap-4 sm:flex-row"
        >
          {config.hero.cta.primary.href === '#inquiry' ? (
            <button
              class="inquiry-trigger bg-mono-black rounded-lg px-8 py-4 font-semibold text-white shadow-lg"
            >
              {config.hero.cta.primary.text}
            </button>
          ) : (
            <a
              href={config.hero.cta.primary.href}
              class="bg-mono-black rounded-lg px-8 py-4 font-semibold text-white shadow-lg"
            >
              {config.hero.cta.primary.text}
            </a>
          )}
          <a
            href={config.hero.cta.secondary.href}
            class="border-mono-black text-mono-black rounded-lg border-2 bg-white px-8 py-4 font-semibold"
          >
            {config.hero.cta.secondary.text}
          </a>
        </div>

        <div
          class="border-mono-lighter mx-auto grid max-w-3xl grid-cols-3 gap-8 border-t pt-20"
        >
          {config.hero.stats.map((stat, index) => (
            <div class={`float scroll-fade-up stagger-${index + 1}`}>
              <div class="text-mono-black mb-2 text-4xl font-bold">
                {stat.value}
              </div>
              <div class="text-mono-gray text-sm tracking-wide uppercase">
                {stat.label}
              </div>
            </div>
          ))}
        </div>
      </div>
    )}
  </div>
</section>
