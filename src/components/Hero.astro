---
import { siteConfig as defaultConfig } from '../config.ts';
import { Image } from 'astro:assets';

const { config = defaultConfig, heroImage } = Astro.props;
const hasImage = !!heroImage;
---

<section
  class="mono-mesh to-mono-lighter relative bg-gradient-to-b from-white px-4 pt-20 pb-12 sm:pt-24 sm:pb-16 lg:pt-32 lg:pb-20 sm:px-6 lg:px-8"
>
  <div class="bg-mono-black absolute top-32 left-0 h-32 w-1"></div>
  <div class="bg-mono-black absolute top-32 right-0 h-32 w-1"></div>

  <div class="mx-auto max-w-7xl">
    {hasImage ? (
      <!-- 左文右图布局 -->
      <div class="grid grid-cols-1 items-center gap-12 lg:grid-cols-2">
        <div>
          <h1
            class="text-mono-heading fade-up mb-6 text-3xl leading-tight font-medium sm:text-4xl lg:text-5xl"
          >
            {config.hero.headline} <span class="text-mono-black">{config.hero.subheadline}</span>
          </h1>
          <p
            class="text-mono-dark fade-up mb-6 text-base leading-relaxed sm:text-lg lg:text-xl"
            style="animation-delay: 100ms"
          >
            {config.hero.description}
          </p>
          {config.hero.trustLine && (
            <p class="text-mono-gray fade-up mb-10 text-sm italic" style="animation-delay: 150ms">
              {config.hero.trustLine}
            </p>
          )}
          <div
            class="fade-up mb-12 flex flex-col gap-4 sm:flex-row"
            style="animation-delay: 200ms"
          >
            {config.hero.cta.primary.href === '#inquiry' ? (
              <button
                class="inquiry-trigger bg-mono-black rounded-lg px-8 py-4 text-center font-semibold text-white shadow-lg"
              >
                {config.hero.cta.primary.text}
              </button>
            ) : (
              <a
                href={config.hero.cta.primary.href}
                class="bg-mono-black rounded-lg px-8 py-4 text-center font-semibold text-white shadow-lg"
              >
                {config.hero.cta.primary.text}
              </a>
            )}
          </div>

          <div
            class="border-mono-lighter grid grid-cols-3 gap-8 border-t pt-8"
          >
            {config.hero.stats.map((stat, index) => (
              <div class={`float fade-up`} style={`animation-delay: ${250 + index * 80}ms`}>
                <div class="text-mono-black mb-2 text-2xl font-medium sm:text-3xl">
                  {stat.value}
                </div>
                <div class="text-mono-gray text-sm tracking-wide uppercase">
                  {stat.label}
                </div>
              </div>
            ))}
          </div>
        </div>

        <div class="fade-left" style="animation-delay: 150ms">
          <Image
            src={heroImage}
            alt={config.hero.headline}
            widths={[400, 600, 800]}
            sizes="(max-width: 1024px) 100vw, 50vw"
            class="w-full max-w-lg rounded-2xl shadow-2xl"
          />
        </div>
      </div>
    ) : (
      <!-- 居中布局（默认） -->
      <div class="mx-auto max-w-4xl text-center">
        <h1
          class="text-mono-heading fade-up mb-6 text-5xl leading-tight font-medium sm:text-6xl lg:text-7xl"
        >
          {config.hero.headline} <span class="text-mono-black">{config.hero.subheadline}</span>
        </h1>
        <p
          class="text-mono-dark fade-up mb-6 text-xl leading-relaxed sm:text-2xl"
          style="animation-delay: 100ms"
        >
          {config.hero.description}
        </p>
        {config.hero.trustLine && (
          <p class="text-mono-gray fade-up mb-10 text-sm italic" style="animation-delay: 150ms">
            {config.hero.trustLine}
          </p>
        )}
        <div
          class="fade-up mb-16 flex flex-col justify-center gap-4 sm:flex-row"
          style="animation-delay: 200ms"
        >
          {config.hero.cta.primary.href === '#inquiry' ? (
            <button
              class="inquiry-trigger bg-mono-black rounded-lg px-8 py-4 font-semibold text-white shadow-lg"
            >
              {config.hero.cta.primary.text}
            </button>
          ) : (
            <a
              href={config.hero.cta.primary.href}
              class="bg-mono-black rounded-lg px-8 py-4 font-semibold text-white shadow-lg"
            >
              {config.hero.cta.primary.text}
            </a>
          )}
        </div>

        <div
          class="border-mono-lighter mx-auto grid max-w-3xl grid-cols-3 gap-8 border-t pt-20"
        >
          {config.hero.stats.map((stat, index) => (
            <div class={`float fade-up`} style={`animation-delay: ${250 + index * 80}ms`}>
              <div class="text-mono-black mb-2 text-4xl font-medium">
                {stat.value}
              </div>
              <div class="text-mono-gray text-sm tracking-wide uppercase">
                {stat.label}
              </div>
            </div>
          ))}
        </div>
      </div>
    )}
  </div>
</section>
