---
import { siteConfig as defaultConfig } from '../config.ts';
import { Icon } from 'astro-icon/components';

const { config = defaultConfig } = Astro.props;

const appIcons: Record<string, string> = {
  'Water Treatment': 'heroicons:funnel',
  'Air Purification': 'heroicons:sparkles',
  'Gold Recovery': 'heroicons:cube',
  'Food & Beverage': 'heroicons:beaker',
  'Pharmaceutical': 'heroicons:shield-check',
  'Chemical & Industrial': 'heroicons:fire',
  'Environmental': 'heroicons:globe-americas',
  'Energy & Gas': 'heroicons:bolt',
};
---

<nav
  class="border-mono-lighter fixed top-0 z-50 w-full border-b bg-white/95 px-4 backdrop-blur-sm sm:px-6 lg:px-8"
>
  <div class="mx-auto max-w-7xl">
    <div class="flex h-16 items-center justify-between">
      <div class="flex items-center">
        <a href="/" class="text-mono-heading text-xl font-bold"
          >{config.site.name}</a
        >
      </div>

      <div class="hidden items-center space-x-8 md:flex">
        {
          config.navigation.links.map((link) =>
            link.children ? (
              <div class="nav-dropdown relative">
                <a href={link.href} class="text-mono-dark inline-flex items-center gap-1 hover:text-mono-heading transition-colors">
                  {link.name}
                  <Icon name="heroicons:chevron-down" class="h-3.5 w-3.5 transition-transform duration-200" />
                </a>
                <div class="nav-dropdown-menu pointer-events-none absolute left-1/2 top-full -translate-x-1/2 pt-3 opacity-0 transition-all duration-200">
                  <div class="w-[480px] rounded-xl border border-mono-lighter bg-white p-4 shadow-xl">
                    <div class="mb-3 border-b border-mono-lighter pb-3">
                      <a href={link.href} class="group flex items-center justify-between rounded-lg bg-mono-lighter px-4 py-2.5 text-sm font-semibold text-mono-heading hover:bg-mono-lighter/80 transition-colors">
                        View All Applications
                        <Icon name="heroicons:arrow-right" class="h-4 w-4 transition-transform group-hover:translate-x-1" />
                      </a>
                    </div>
                    <div class="grid grid-cols-2 gap-1">
                      {link.children.map((child) => (
                        <a href={child.href} class="flex items-center gap-3 rounded-lg px-3 py-2.5 text-sm text-mono-dark hover:bg-mono-lighter/60 hover:text-mono-heading transition-colors">
                          <Icon name={appIcons[child.name] || 'heroicons:arrow-right'} class="h-4 w-4 flex-shrink-0 text-mono-black/40" />
                          {child.name}
                        </a>
                      ))}
                    </div>
                  </div>
                </div>
              </div>
            ) : (
              <a href={link.href} class="text-mono-dark hover:text-mono-heading transition-colors">
                {link.name}
              </a>
            )
          )
        }
        {config.navigation.cta.href === '#inquiry' ? (
          <button
            class="inquiry-trigger bg-mono-black rounded-lg px-6 py-2 text-white"
          >
            {config.navigation.cta.text}
          </button>
        ) : (
          <a
            href={config.navigation.cta.href}
            class="bg-mono-black rounded-lg px-6 py-2 text-white"
          >
            {config.navigation.cta.text}
          </a>
        )}
      </div>

      <button
        id="mobileMenuButton"
        class="rounded-lg p-2 md:hidden"
        aria-controls="mobileMenu"
        aria-expanded="false"
        aria-label="Toggle navigation menu"
      >
        <Icon name="heroicons:bars-3" class="text-mono-heading h-6 w-6" />
      </button>
    </div>

    <div id="mobileMenu" class="hidden pb-4 md:hidden" aria-hidden="true">
      <div class="flex flex-col space-y-1">
        {
          config.navigation.links.map((link) =>
            link.children ? (
              <div class="mobile-dropdown">
                <button class="mobile-dropdown-toggle flex w-full items-center justify-between py-2 text-mono-dark" type="button">
                  {link.name}
                  <Icon name="heroicons:chevron-down" class="h-4 w-4 transition-transform duration-200" />
                </button>
                <div class="mobile-dropdown-menu hidden pl-2 pb-2">
                  <a href={link.href} class="flex items-center gap-2 px-3 py-2 mb-1 text-sm font-medium text-mono-heading border-b border-mono-lighter pb-3">
                    View All
                    <Icon name="heroicons:arrow-right" class="h-3.5 w-3.5" />
                  </a>
                  {link.children.map((child) => (
                    <a href={child.href} class="flex items-center gap-2.5 rounded-lg px-3 py-2 text-sm text-mono-dark">
                      <Icon name={appIcons[child.name] || 'heroicons:arrow-right'} class="h-4 w-4 flex-shrink-0 text-mono-black/40" />
                      {child.name}
                    </a>
                  ))}
                </div>
              </div>
            ) : (
              <a href={link.href} class="text-mono-dark py-2">
                {link.name}
              </a>
            )
          )
        }
        {config.navigation.cta.href === '#inquiry' ? (
          <button
            class="inquiry-trigger bg-mono-black rounded-lg px-6 py-3 text-center text-white w-full"
          >
            {config.navigation.cta.text}
          </button>
        ) : (
          <a
            href={config.navigation.cta.href}
            class="bg-mono-black rounded-lg px-6 py-3 text-center text-white"
          >
            {config.navigation.cta.text}
          </a>
        )}
      </div>
    </div>
  </div>
</nav>

<style>
  .nav-dropdown-menu {
    transform: translateY(4px);
  }
  .nav-dropdown:hover .nav-dropdown-menu {
    opacity: 1;
    pointer-events: auto;
    transform: translateY(0);
  }
  .nav-dropdown:hover > a > svg {
    transform: rotate(180deg);
  }
  .mobile-dropdown-toggle.active svg {
    transform: rotate(180deg);
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const mobileMenuButton = document.getElementById('mobileMenuButton');
    const mobileMenu = document.getElementById('mobileMenu');

    if (mobileMenuButton && mobileMenu) {
      mobileMenuButton.addEventListener('click', () => {
        const isExpanded =
          mobileMenuButton.getAttribute('aria-expanded') === 'true';
        mobileMenuButton.setAttribute('aria-expanded', String(!isExpanded));
        mobileMenu.setAttribute('aria-hidden', String(isExpanded));
        mobileMenu.classList.toggle('hidden');
      });

      const mobileMenuLinks = mobileMenu.querySelectorAll('a');
      mobileMenuLinks.forEach((link) => {
        link.addEventListener('click', () => {
          mobileMenuButton.setAttribute('aria-expanded', 'false');
          mobileMenu.setAttribute('aria-hidden', 'true');
          mobileMenu.classList.add('hidden');
        });
      });
    }

    document.querySelectorAll('.mobile-dropdown-toggle').forEach((toggle) => {
      toggle.addEventListener('click', () => {
        const menu = toggle.nextElementSibling;
        if (menu) {
          menu.classList.toggle('hidden');
          toggle.classList.toggle('active');
        }
      });
    });
  });
</script>
