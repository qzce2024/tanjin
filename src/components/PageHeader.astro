---
interface Props {
  title: string;
  subtitle?: string;
}

const { title, subtitle } = Astro.props;
---

<section class="mono-mesh to-mono-lighter relative bg-gradient-to-b from-white px-4 pt-32 pb-16 sm:px-6 lg:px-8">
  <div class="mx-auto max-w-4xl text-center">
    <h1 class="text-mono-heading fade-up mb-4 text-3xl font-bold sm:text-4xl lg:text-5xl">
      {title}
    </h1>
    {subtitle && (
      <p class="text-mono-dark fade-up text-base leading-relaxed sm:text-lg lg:text-xl" style="animation-delay: 100ms">
        {subtitle}
      </p>
    )}
  </div>
</section>
