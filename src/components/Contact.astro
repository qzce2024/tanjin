---
import { siteConfig as defaultConfig } from '../config.ts';
import { Icon } from 'astro-icon/components';

const { config = defaultConfig } = Astro.props;
---

<section id="contact" class="bg-mono-lighter section-lg px-4 sm:px-6 lg:px-8">
  <div class="mx-auto max-w-7xl">
    <div class="grid grid-cols-1 items-start gap-12 lg:grid-cols-2">
      <!-- Left -->
      <div class="scroll-fade-left">
        <h2 class="text-mono-heading mb-4 text-3xl font-bold leading-tight sm:text-4xl lg:text-5xl">
          {config.contact.title}
        </h2>
        <p class="text-mono-dark mb-10 text-base leading-relaxed sm:text-lg lg:text-xl">
          Get the right carbon grade, pricing, and samples — all in one conversation. No back-and-forth with middlemen.
        </p>

        <div class="space-y-3">
          <a
            href={`mailto:${config.contact.email}`}
            class="text-mono-black flex items-center gap-3 font-semibold hover:underline"
          >
            <Icon name="heroicons:envelope" class="h-5 w-5 shrink-0" />
            {config.contact.email}
          </a>
          {config.contact.phone && (
            <a
              href={`tel:${config.contact.phone}`}
              class="text-mono-black flex items-center gap-3 font-semibold hover:underline"
            >
              <Icon name="heroicons:phone" class="h-5 w-5 shrink-0" />
              {config.contact.phone}
            </a>
          )}
        </div>
      </div>

      <!-- Right: Form -->
      <div
        class="scroll-fade-right rounded-2xl bg-white p-6 shadow-lg sm:p-8"
      >
        <form id="contactForm" action="https://api.web3forms.com/submit" method="POST" class="space-y-5">
          <input type="hidden" name="access_key" value="fa886cef-962b-44d9-a0c6-f86678b0c2cc" />
          <input type="hidden" name="subject" value="New Inquiry from Tanjin Carbon Website" />
          <input type="hidden" name="from_name" value="Tanjin Carbon Website" />
          <input type="checkbox" name="botcheck" class="hidden" style="display:none" />
          <input type="hidden" name="IP Address" id="hiddenIp" value="" />
          <input type="hidden" name="Country" id="hiddenCountry" value="" />
          <input type="hidden" name="Browser" id="hiddenBrowser" value="" />
          <input type="hidden" name="Language" id="hiddenLang" value="" />
          <input type="hidden" name="Page URL" id="hiddenPage" value="" />
          <input type="hidden" name="Screen Size" id="hiddenScreen" value="" />
          <input type="hidden" name="Timezone" id="hiddenTimezone" value="" />
          <div>
            <label
              for="name"
              class="text-mono-heading mb-2 block text-sm font-semibold"
              >{config.contact.form.fields.name.label}</label
            >
            <input
              type="text"
              id="name"
              name="name"
              required={config.contact.form.fields.name.required}
              class="border-mono-lighter w-full rounded-lg border px-4 py-3 transition-all duration-200"
              placeholder={config.contact.form.fields.name.placeholder}
            />
          </div>

          <div>
            <label
              for="email"
              class="text-mono-heading mb-2 block text-sm font-semibold"
              >{config.contact.form.fields.email.label}</label
            >
            <input
              type="email"
              id="email"
              name="email"
              required={config.contact.form.fields.email.required}
              class="border-mono-lighter w-full rounded-lg border px-4 py-3 transition-all duration-200"
              placeholder={config.contact.form.fields.email.placeholder}
            />
          </div>

          <div>
            <label
              for="company"
              class="text-mono-heading mb-2 block text-sm font-semibold"
              >{config.contact.form.fields.company.label}</label
            >
            <input
              type="text"
              id="company"
              name="company"
              class="border-mono-lighter w-full rounded-lg border px-4 py-3 transition-all duration-200"
              placeholder={config.contact.form.fields.company.placeholder}
            />
          </div>

          <div>
            <label
              for="message"
              class="text-mono-heading mb-2 block text-sm font-semibold"
              >{config.contact.form.fields.message.label}</label
            >
            <textarea
              id="message"
              name="message"
              rows="4"
              class="form-input border-mono-lighter w-full resize-none rounded-lg border px-4 py-3 transition-all duration-200"
              placeholder={config.contact.form.fields.message.placeholder}
            ></textarea>
          </div>

          <div id="formSuccess" class="hidden rounded-lg bg-green-50 p-4 text-center text-sm font-medium text-green-700">
            Thank you! We'll get back to you within 24 hours.
          </div>
          <div id="formError" class="hidden rounded-lg bg-red-50 p-4 text-center text-sm font-medium text-red-700">
            Something went wrong. Please try again or email us directly.
          </div>

          <button
            type="submit"
            id="submitBtn"
            class="bg-mono-black w-full rounded-lg px-6 py-4 font-semibold text-white shadow-lg transition-all duration-200 hover:shadow-xl"
          >
            {config.contact.form.cta}
          </button>

          <p class="text-mono-gray text-center text-xs leading-relaxed">
            By submitting this form, you agree to our
            <a href="#" class="underline">Terms of Service</a> and
            <a href="#" class="underline">Privacy Policy</a>
          </p>
        </form>
      </div>
    </div>
  </div>
</section>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const form = document.getElementById('contactForm') as HTMLFormElement;
    const submitBtn = document.getElementById('submitBtn') as HTMLButtonElement;
    const successMsg = document.getElementById('formSuccess')!;
    const errorMsg = document.getElementById('formError')!;
    const btnText = submitBtn.textContent || '';

    // Collect visitor info
    (document.getElementById('hiddenBrowser') as HTMLInputElement).value = navigator.userAgent;
    (document.getElementById('hiddenLang') as HTMLInputElement).value = navigator.language;
    (document.getElementById('hiddenPage') as HTMLInputElement).value = window.location.href;
    (document.getElementById('hiddenScreen') as HTMLInputElement).value = `${screen.width}x${screen.height}`;
    (document.getElementById('hiddenTimezone') as HTMLInputElement).value = Intl.DateTimeFormat().resolvedOptions().timeZone;

    // Reuse shared IP data from InquiryModal, or fetch if not available
    if (!(window as any).__ipDataPromise) {
      (window as any).__ipDataPromise = fetch('https://ipapi.co/json/')
        .then(r => r.json())
        .catch(() => null);
    }
    (window as any).__ipDataPromise.then((ipData: any) => {
      if (!ipData) return;
      (document.getElementById('hiddenIp') as HTMLInputElement).value = ipData.ip || '';
      (document.getElementById('hiddenCountry') as HTMLInputElement).value = `${ipData.country_name || ''} (${ipData.city || ''})`;
    });

    if (form) {
      form.addEventListener('submit', async (e) => {
        e.preventDefault();
        submitBtn.disabled = true;
        submitBtn.textContent = 'Sending...';
        successMsg.classList.add('hidden');
        errorMsg.classList.add('hidden');

        try {
          const res = await fetch(form.action, {
            method: 'POST',
            body: new FormData(form),
          });
          const data = await res.json();

          if (data.success) {
            successMsg.classList.remove('hidden');
            form.reset();
          } else {
            errorMsg.classList.remove('hidden');
          }
        } catch {
          errorMsg.classList.remove('hidden');
        } finally {
          submitBtn.disabled = false;
          submitBtn.textContent = btnText;
        }
      });
    }
  });
</script>
