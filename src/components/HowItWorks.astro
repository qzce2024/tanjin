---
import { siteConfig as defaultConfig } from '../config.ts';
import { howItWorksSteps as defaultSteps } from '../content/how-it-works';

const { config = defaultConfig, steps = defaultSteps } = Astro.props;
---

<section
  id="how-it-works"
  class="bg-white relative section-lg px-4 sm:px-6 lg:px-8"
>
  <div class="mx-auto max-w-7xl">
    <div class="scroll-fade-down mx-auto mb-12 max-w-3xl text-center">
      <h2 class="text-mono-heading mb-4 text-2xl font-medium sm:text-3xl lg:text-4xl">
        {config.howItWorks.title}
      </h2>
      <p class="text-mono-dark text-base sm:text-lg">
        {config.howItWorks.subtitle}
      </p>
    </div>

    {/* Desktop: horizontal timeline */}
    <div class="hidden lg:block">
      {/* connector line */}
      <div class="relative mx-auto max-w-5xl">
        <div class="absolute top-5 right-8 left-8 h-0.5 bg-mono-black/15"></div>
        <div class="grid grid-cols-4 gap-4">
          {
            steps.map((step) => (
              <div class="scroll-fade-up group relative cursor-default text-center">
                <div class="bg-mono-black mx-auto mb-4 flex h-11 w-11 items-center justify-center rounded-full text-base font-medium text-white transition-transform duration-200 group-hover:scale-110">
                  {step.number}
                </div>
                <h3 class="text-mono-heading mb-1.5 text-base font-semibold">
                  {step.title}
                </h3>
                <p class="text-mono-dark text-sm leading-relaxed">{step.description}</p>
              </div>
            ))
          }
        </div>
      </div>
    </div>

    {/* Mobile/Tablet: vertical compact timeline */}
    <div class="lg:hidden">
      <div class="relative ml-5">
        {/* vertical line */}
        <div class="absolute top-0 bottom-0 left-0 w-0.5 bg-mono-black/15"></div>
        <div class="space-y-6">
          {
            steps.map((step) => (
              <div class="relative pl-8">
                <div class="bg-mono-black absolute -left-3.5 top-0 flex h-7 w-7 items-center justify-center rounded-full text-xs font-medium text-white">
                  {step.number}
                </div>
                <h3 class="text-mono-heading text-base font-semibold">{step.title}</h3>
                <p class="text-mono-dark mt-1 text-sm leading-relaxed">{step.description}</p>
              </div>
            ))
          }
        </div>
      </div>
    </div>
  </div>
</section>
