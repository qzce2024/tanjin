---
import { Icon } from 'astro-icon/components';

interface TrustLogo {
  icon: string;
  label: string;
}

interface Props {
  logos: TrustLogo[];
}

const { logos = [] } = Astro.props;
---

<section class="border-mono-lighter border-b bg-mono-lighter px-4 py-6 sm:px-6 lg:px-8">
  <div class="mx-auto max-w-5xl">
    <div class="flex flex-wrap items-center justify-center gap-8 sm:gap-12">
      {
        logos.map((logo) => (
          <div class="flex items-center gap-2 opacity-60 transition-opacity duration-200 hover:opacity-100">
            <Icon name={logo.icon} class="text-mono-heading h-6 w-6" />
            <span class="text-mono-gray text-xs font-medium tracking-wide uppercase">
              {logo.label}
            </span>
          </div>
        ))
      }
    </div>
  </div>
</section>
