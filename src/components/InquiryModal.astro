---
// Global inquiry modal - include once in layout, triggered by any .inquiry-trigger button
---

<div
  id="inquiryModal"
  class="fixed inset-0 z-[100] hidden items-center justify-center"
  aria-hidden="true"
  role="dialog"
  aria-modal="true"
  aria-label="Inquiry form"
>
  <!-- Backdrop -->
  <div id="inquiryBackdrop" class="absolute inset-0 bg-black/50 backdrop-blur-sm"></div>

  <!-- Modal -->
  <div
    class="relative mx-4 w-full max-w-lg rounded-2xl bg-white p-6 shadow-2xl sm:p-8"
  >
    <!-- Close button -->
    <button
      id="inquiryClose"
      class="text-mono-gray hover:text-mono-heading absolute top-4 right-4 p-1"
      aria-label="Close inquiry form"
    >
      <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
      </svg>
    </button>

    <!-- Header -->
    <h3 class="text-mono-heading mb-1 text-xl font-bold sm:text-2xl">
      Request a Quote
    </h3>
    <p id="inquiryProduct" class="text-mono-gray mb-6 text-sm"></p>

    <!-- Form -->
    <form id="inquiryForm" class="space-y-4">
      <div>
        <label for="inq-name" class="text-mono-heading mb-1 block text-sm font-semibold">
          Contact Name <span class="text-red-500">*</span>
        </label>
        <input
          type="text"
          id="inq-name"
          name="name"
          required
          class="border-mono-lighter w-full rounded-lg border px-4 py-2.5 text-sm"
          placeholder="Your full name"
        />
      </div>

      <div>
        <label for="inq-email" class="text-mono-heading mb-1 block text-sm font-semibold">
          Email <span class="text-red-500">*</span>
        </label>
        <input
          type="email"
          id="inq-email"
          name="email"
          required
          class="border-mono-lighter w-full rounded-lg border px-4 py-2.5 text-sm"
          placeholder="your@company.com"
        />
      </div>

      <div>
        <label for="inq-company" class="text-mono-heading mb-1 block text-sm font-semibold">
          Company
        </label>
        <input
          type="text"
          id="inq-company"
          name="company"
          class="border-mono-lighter w-full rounded-lg border px-4 py-2.5 text-sm"
          placeholder="Your Company Ltd."
        />
      </div>

      <div>
        <label for="inq-message" class="text-mono-heading mb-1 block text-sm font-semibold">
          Requirements
        </label>
        <textarea
          id="inq-message"
          name="message"
          rows="3"
          class="border-mono-lighter w-full resize-none rounded-lg border px-4 py-2.5 text-sm"
          placeholder="Product type, specifications, quantity, application..."
        ></textarea>
      </div>

      <button
        type="submit"
        class="bg-mono-black w-full rounded-lg px-6 py-3 text-sm font-semibold text-white shadow-lg"
      >
        Send Inquiry
      </button>

      <p class="text-mono-gray text-center text-xs">
        We typically respond within 24 hours.
      </p>
    </form>
  </div>
</div>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const modal = document.getElementById('inquiryModal');
    const backdrop = document.getElementById('inquiryBackdrop');
    const closeBtn = document.getElementById('inquiryClose');
    const form = document.getElementById('inquiryForm') as HTMLFormElement;
    const productLabel = document.getElementById('inquiryProduct');

    function openModal(product?: string) {
      if (!modal) return;
      if (productLabel) {
        productLabel.textContent = product || 'Tell us about your activated carbon needs.';
      }
      modal.classList.remove('hidden');
      modal.classList.add('flex');
      modal.setAttribute('aria-hidden', 'false');
      document.body.style.overflow = 'hidden';
    }

    function closeModal() {
      if (!modal) return;
      modal.classList.add('hidden');
      modal.classList.remove('flex');
      modal.setAttribute('aria-hidden', 'true');
      document.body.style.overflow = '';
    }

    // All .inquiry-trigger buttons open the modal
    document.querySelectorAll('.inquiry-trigger').forEach((btn) => {
      btn.addEventListener('click', (e) => {
        e.preventDefault();
        const product = (btn as HTMLElement).dataset.product;
        openModal(product);
      });
    });

    // Close handlers
    backdrop?.addEventListener('click', closeModal);
    closeBtn?.addEventListener('click', closeModal);
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') closeModal();
    });

    // Form submit
    form?.addEventListener('submit', (e) => {
      e.preventDefault();
      alert('Thank you for your inquiry! We will get back to you within 24 hours.');
      form.reset();
      closeModal();
    });
  });
</script>
