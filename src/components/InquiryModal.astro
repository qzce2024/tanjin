---
// Global inquiry modal - include once in layout, triggered by any .inquiry-trigger button
---

<div
  id="inquiryModal"
  class="fixed inset-0 z-[100] hidden items-center justify-center"
  aria-hidden="true"
  role="dialog"
  aria-modal="true"
  aria-label="Inquiry form"
>
  <!-- Backdrop -->
  <div id="inquiryBackdrop" class="absolute inset-0 bg-black/50 backdrop-blur-sm"></div>

  <!-- Modal -->
  <div
    class="relative mx-4 w-full max-w-lg rounded-2xl bg-white p-6 shadow-2xl sm:p-8"
  >
    <!-- Close button -->
    <button
      id="inquiryClose"
      class="text-mono-gray hover:text-mono-heading absolute top-4 right-4 p-1"
      aria-label="Close inquiry form"
    >
      <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
      </svg>
    </button>

    <!-- Header -->
    <h3 class="text-mono-heading mb-1 text-xl font-bold sm:text-2xl">
      Request a Quote
    </h3>
    <p id="inquiryProduct" class="text-mono-gray mb-6 text-sm"></p>

    <!-- Form -->
    <form id="inquiryForm" action="https://api.web3forms.com/submit" method="POST" class="space-y-4">
      <input type="hidden" name="access_key" value="fa886cef-962b-44d9-a0c6-f86678b0c2cc" />
      <input type="hidden" name="subject" value="New Inquiry from Tanjin Carbon Website" />
      <input type="hidden" name="from_name" value="Tanjin Carbon Website" />
      <input type="checkbox" name="botcheck" class="hidden" style="display:none" />
      <input type="hidden" name="IP Address" id="inq-hiddenIp" value="" />
      <input type="hidden" name="Country" id="inq-hiddenCountry" value="" />
      <input type="hidden" name="Browser" id="inq-hiddenBrowser" value="" />
      <input type="hidden" name="Language" id="inq-hiddenLang" value="" />
      <input type="hidden" name="Page URL" id="inq-hiddenPage" value="" />
      <input type="hidden" name="Screen Size" id="inq-hiddenScreen" value="" />
      <input type="hidden" name="Timezone" id="inq-hiddenTimezone" value="" />
      <input type="hidden" name="Product Interest" id="inq-hiddenProduct" value="" />
      <div>
        <label for="inq-name" class="text-mono-heading mb-1 block text-sm font-semibold">
          Contact Name <span class="text-red-500">*</span>
        </label>
        <input
          type="text"
          id="inq-name"
          name="name"
          required
          class="border-mono-lighter w-full rounded-lg border px-4 py-2.5 text-sm"
          placeholder="Your full name"
        />
      </div>

      <div>
        <label for="inq-email" class="text-mono-heading mb-1 block text-sm font-semibold">
          Email <span class="text-red-500">*</span>
        </label>
        <input
          type="email"
          id="inq-email"
          name="email"
          required
          class="border-mono-lighter w-full rounded-lg border px-4 py-2.5 text-sm"
          placeholder="your@company.com"
        />
      </div>

      <div>
        <label for="inq-company" class="text-mono-heading mb-1 block text-sm font-semibold">
          Phone / WhatsApp
        </label>
        <input
          type="text"
          id="inq-company"
          name="phone"
          class="border-mono-lighter w-full rounded-lg border px-4 py-2.5 text-sm"
          placeholder="+1 234 567 8900"
        />
      </div>

      <div>
        <label for="inq-message" class="text-mono-heading mb-1 block text-sm font-semibold">
          Requirements
        </label>
        <textarea
          id="inq-message"
          name="message"
          rows="3"
          class="border-mono-lighter w-full resize-none rounded-lg border px-4 py-2.5 text-sm"
          placeholder="Product type, specifications, quantity, application..."
        ></textarea>
      </div>

      <button
        type="submit"
        id="inqSubmitBtn"
        class="bg-mono-black w-full rounded-lg px-6 py-3 text-sm font-semibold text-white shadow-lg"
      >
        Send Inquiry
      </button>

      <div id="inqSuccess" class="hidden rounded-lg bg-green-50 p-3 text-center text-sm font-medium text-green-700">
        Thank you! We'll get back to you within 24 hours.
      </div>
      <div id="inqError" class="hidden rounded-lg bg-red-50 p-3 text-center text-sm font-medium text-red-700">
        Something went wrong. Please try again or email us directly.
      </div>

      <p class="text-mono-gray text-center text-xs">
        We typically respond within 24 hours.
      </p>
    </form>
  </div>
</div>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const modal = document.getElementById('inquiryModal');
    const backdrop = document.getElementById('inquiryBackdrop');
    const closeBtn = document.getElementById('inquiryClose');
    const form = document.getElementById('inquiryForm') as HTMLFormElement;
    const productLabel = document.getElementById('inquiryProduct');
    const submitBtn = document.getElementById('inqSubmitBtn') as HTMLButtonElement;
    const successMsg = document.getElementById('inqSuccess')!;
    const errorMsg = document.getElementById('inqError')!;
    const btnText = submitBtn?.textContent || '';

    // Collect visitor info
    const setVal = (id: string, val: string) => {
      const el = document.getElementById(id) as HTMLInputElement;
      if (el) el.value = val;
    };
    setVal('inq-hiddenBrowser', navigator.userAgent);
    setVal('inq-hiddenLang', navigator.language);
    setVal('inq-hiddenPage', window.location.href);
    setVal('inq-hiddenScreen', `${screen.width}x${screen.height}`);
    setVal('inq-hiddenTimezone', Intl.DateTimeFormat().resolvedOptions().timeZone);

    // Lazy fetch IP info — shared via window, non-blocking
    if (!(window as any).__ipDataPromise) {
      (window as any).__ipDataPromise = fetch('https://ipapi.co/json/')
        .then(r => r.json())
        .catch(() => null);
    }
    (window as any).__ipDataPromise.then((ipData: any) => {
      if (!ipData) return;
      setVal('inq-hiddenIp', ipData.ip || '');
      setVal('inq-hiddenCountry', `${ipData.country_name || ''} (${ipData.city || ''})`);
      // Also fill contact form fields if they exist
      const contactIp = document.getElementById('hiddenIp') as HTMLInputElement;
      const contactCountry = document.getElementById('hiddenCountry') as HTMLInputElement;
      if (contactIp) contactIp.value = ipData.ip || '';
      if (contactCountry) contactCountry.value = `${ipData.country_name || ''} (${ipData.city || ''})`;
    });

    function openModal(product?: string) {
      if (!modal) return;
      if (productLabel) {
        productLabel.textContent = product || 'Tell us about your activated carbon needs.';
      }
      setVal('inq-hiddenProduct', product || '');
      modal.classList.remove('hidden');
      modal.classList.add('flex');
      modal.setAttribute('aria-hidden', 'false');
      document.body.style.overflow = 'hidden';
      successMsg.classList.add('hidden');
      errorMsg.classList.add('hidden');
    }

    function closeModal() {
      if (!modal) return;
      modal.classList.add('hidden');
      modal.classList.remove('flex');
      modal.setAttribute('aria-hidden', 'true');
      document.body.style.overflow = '';
    }

    // All .inquiry-trigger buttons open the modal
    document.querySelectorAll('.inquiry-trigger').forEach((btn) => {
      btn.addEventListener('click', (e) => {
        e.preventDefault();
        const product = (btn as HTMLElement).dataset.product;
        openModal(product);
      });
    });

    // Close handlers
    backdrop?.addEventListener('click', closeModal);
    closeBtn?.addEventListener('click', closeModal);
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') closeModal();
    });

    // Form submit
    form?.addEventListener('submit', async (e) => {
      e.preventDefault();
      submitBtn.disabled = true;
      submitBtn.textContent = 'Sending...';
      successMsg.classList.add('hidden');
      errorMsg.classList.add('hidden');

      try {
        const res = await fetch(form.action, {
          method: 'POST',
          body: new FormData(form),
        });
        const data = await res.json();

        if (data.success) {
          successMsg.classList.remove('hidden');
          form.reset();
        } else {
          errorMsg.classList.remove('hidden');
        }
      } catch {
        errorMsg.classList.remove('hidden');
      } finally {
        submitBtn.disabled = false;
        submitBtn.textContent = btnText;
      }
    });
  });
</script>
