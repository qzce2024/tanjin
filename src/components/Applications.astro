---
import { Icon } from 'astro-icon/components';

interface ApplicationItem {
  icon: string;
  title: string;
  description: string;
}

interface Props {
  title?: string;
  subtitle?: string;
  items?: ApplicationItem[];
  ctaText?: string;
}

const {
  title = 'Applications',
  subtitle = 'Serving diverse industries worldwide',
  items = [],
  ctaText = 'Not sure which grade fits your application?',
} = Astro.props;
---

<section
  id="applications"
  class="bg-mono-lighter relative section-lg px-4 sm:px-6 lg:px-8"
>
  <div class="mx-auto max-w-7xl">
    <div class="scroll-fade-up mx-auto mb-16 max-w-3xl text-center">
      <h2 class="text-mono-heading mb-4 text-2xl font-bold sm:text-3xl lg:text-4xl">
        {title}
      </h2>
      <p class="text-mono-dark text-base sm:text-lg">
        {subtitle}
      </p>
    </div>

    <div class="grid grid-cols-2 gap-x-8 gap-y-10 sm:gap-x-12 sm:gap-y-12 lg:grid-cols-4">
      {
        items.map((item, index) => (
          <div class={`scroll-fade-up group cursor-default stagger-${(index % 9) + 1}`}>
            <div class="bg-mono-black/5 mb-3 inline-flex rounded-lg p-2.5 transition-colors duration-200 group-hover:bg-mono-black/10">
              <Icon name={item.icon} class="text-mono-heading h-7 w-7 sm:h-8 sm:w-8" />
            </div>
            <h3 class="text-mono-heading mb-1.5 text-sm font-semibold sm:text-base">
              {item.title}
            </h3>
            <p class="text-mono-dark text-xs leading-relaxed sm:text-sm">
              {item.description}
            </p>
          </div>
        ))
      }
    </div>

    <div class="scroll-fade-up mt-14 text-center">
      <p class="text-mono-dark mb-4 text-sm sm:text-base">{ctaText}</p>
      <button
        class="inquiry-trigger bg-mono-black rounded-lg px-6 py-3 text-sm font-semibold text-white"
      >
        Talk to an Engineer
      </button>
    </div>
  </div>
</section>
