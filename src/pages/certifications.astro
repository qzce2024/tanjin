---
import BaseLayout from '../layouts/BaseLayout.astro';
import { homeConfig } from '../content/home/config';
import { certificationsData } from '../content/certifications';
import Navigation from '../components/Navigation.astro';
import PageCTA from '../components/PageCTA.astro';
import Footer from '../components/Footer.astro';
import { Icon } from 'astro-icon/components';
import { Image } from 'astro:assets';
import certHeroBg from '../assets/images/certifications/cert-hero.png';
import certCtaBg from '../assets/images/certifications/cert-cta.png';

const d = certificationsData;
---

<BaseLayout
  title="Certifications & Quality - Tanjin Carbon"
  description="ISO 9001, NSF/ANSI 61, HALAL, KOSHER certified activated carbon. SGS tested with batch-specific COA reports."
>
  <Navigation config={homeConfig} />

  <!-- Hero -->
  <section class="relative overflow-hidden px-4 pt-32 pb-20 sm:px-6 lg:px-8">
    <Image src={certHeroBg} alt="" widths={[800, 1200, 1920]} sizes="100vw" class="absolute inset-0 h-full w-full object-cover" loading="eager" />
    <div class="absolute inset-0 bg-mono-heading/75"></div>
    <div class="relative mx-auto max-w-4xl text-center">
      <h1 class="scroll-fade-up mb-4 text-3xl font-extrabold text-white sm:text-4xl lg:text-5xl">Certifications & Quality</h1>
      <p class="scroll-fade-up mx-auto max-w-2xl text-base leading-relaxed text-white/85 sm:text-lg lg:text-xl">
        Internationally certified products backed by rigorous testing — every batch verified before shipment
      </p>
    </div>
  </section>

  <!-- Quality Intro -->
  <section class="bg-white pt-20 px-4 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-7xl text-center">
      <h2 class="text-mono-heading mb-4 text-2xl font-bold sm:text-3xl lg:text-4xl">{d.qualityStory.title}</h2>
      <p class="text-mono-dark mx-auto max-w-3xl text-base sm:text-lg">{d.qualityStory.subtitle}</p>
    </div>
  </section>

  <!-- Steps: unified alternating layout -->
  {d.steps.map((item, i) => (
    <section class={`section-lg px-4 sm:px-6 lg:px-8 ${i % 2 === 0 ? 'bg-white' : 'bg-mono-lighter'}`}>
      <div class="mx-auto max-w-7xl">
        <div class="grid grid-cols-1 items-center gap-12 lg:grid-cols-2">
          <div class={`overflow-hidden rounded-2xl ${i % 2 === 1 ? 'lg:order-2' : ''}`}>
            <Image src={item.image} alt={item.title} widths={[500, 800]} sizes="(max-width: 1024px) 100vw, 50vw" class="w-full object-cover" />
          </div>
          <div class={i % 2 === 1 ? 'lg:order-1' : ''}>
            <span class="text-mono-black mb-3 inline-block text-sm font-semibold uppercase tracking-wide">Step {item.step}</span>
            <h3 class="text-mono-heading mb-4 text-2xl font-bold">{item.title}</h3>
            <p class="text-mono-dark mb-6 text-base leading-relaxed">{item.description}</p>
            <ul class="space-y-3">
              {item.points.map((p) => (
                <li class="flex items-start gap-3">
                  <Icon name="heroicons:check-circle-solid" class="text-mono-black mt-0.5 h-5 w-5 flex-shrink-0" />
                  <span class="text-mono-dark text-sm sm:text-base">{p}</span>
                </li>
              ))}
            </ul>
          </div>
        </div>
      </div>
    </section>
  ))}

  <!-- Factory & Equipment Gallery -->
  <section class="bg-white section-lg px-4 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-7xl">
      <div class="mb-10 text-center">
        <h2 class="text-mono-heading mb-4 text-2xl font-bold sm:text-3xl">Our Factory & Equipment</h2>
        <p class="text-mono-dark text-base sm:text-lg">A look inside our production facility in Longyan, Fujian, China</p>
      </div>
      <div class="grid grid-cols-2 gap-4 lg:grid-cols-4">
        {d.gallery.map((item) => (
          <div class="overflow-hidden rounded-xl">
            <Image src={item.image} alt={item.alt} widths={[300, 500]} sizes="(max-width: 1024px) 50vw, 25vw" class="h-48 w-full object-cover transition-transform duration-300 hover:scale-105 sm:h-56" />
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Certifications -->
  <section class="bg-mono-lighter section-lg px-4 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-7xl">
      <div class="mb-10 text-center">
        <h2 class="text-mono-heading mb-4 text-2xl font-bold sm:text-3xl">Our Certifications</h2>
        <p class="text-mono-dark text-base sm:text-lg">Recognized by international standards organizations</p>
      </div>
      <div class="grid grid-cols-2 gap-6 sm:grid-cols-4">
        {d.certificates.map((cert) => (
          <div class="rounded-xl bg-white px-6 py-8 text-center shadow-sm">
            <div class="text-mono-heading text-xl font-bold">{cert.name}</div>
            <div class="text-mono-gray mt-1 text-sm">{cert.scope}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <PageCTA
    title="Request Samples & Test Reports"
    description="Get free samples with full COA reports to verify our quality firsthand."
    buttonText="Request Free Samples"
    buttonHref="#inquiry"
    bgImage={certCtaBg}
  />
  <Footer config={homeConfig} />
</BaseLayout>
