---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { homeConfig } from '../../content/home/config';
import { environmentalData } from '../../content/applications/environmental';
import Navigation from '../../components/Navigation.astro';
import PageCTA from '../../components/PageCTA.astro';
import Footer from '../../components/Footer.astro';
import { Image } from 'astro:assets';
import { Icon } from 'astro-icon/components';

const d = environmentalData;
---

<BaseLayout title={d.meta.title} description={d.meta.description}>
  <Navigation config={homeConfig} />

  <!-- Hero: Left text + Right image -->
  <section class="relative pt-20 lg:pt-0" style="background: linear-gradient(180deg, #FAFCFF 0%, #EDF4FF 100%);">
    <div class="px-4 sm:px-6 lg:px-8">
      <div class="mx-auto max-w-7xl">
        <div class="grid grid-cols-1 lg:grid-cols-2 lg:min-h-[80vh] lg:items-center lg:gap-12">
          <div class="py-14 sm:py-20 lg:py-28">
            <h1 class="fade-up mb-5 text-3xl font-medium text-mono-heading sm:text-4xl lg:text-5xl">
              {d.hero.title}
            </h1>
            <p class="fade-up mb-10 text-base leading-relaxed text-mono-dark/80 sm:text-lg lg:text-xl lg:leading-relaxed" style="animation-delay: 100ms">
              {d.hero.description}
            </p>
            <div class="fade-up" style="animation-delay: 200ms">
              <button class="inquiry-trigger group inline-flex items-center gap-2 rounded-lg bg-white px-7 py-3.5 text-sm font-semibold text-mono-heading shadow-sm border border-mono-lighter transition-all hover:shadow-md">
                {d.hero.buttonText}
                <Icon name="heroicons:arrow-right" class="h-4 w-4 transition-transform group-hover:translate-x-1" />
              </button>
            </div>
          </div>
        </div>
      </div>
    </div>
    <div class="relative lg:absolute lg:right-0 lg:top-0 lg:h-full lg:w-1/2">
      <Image src={d.mainImage} alt="Environmental remediation application" widths={[600, 900, 1200]} sizes="(max-width: 1024px) 100vw, 50vw" class="h-72 w-full object-cover sm:h-96 lg:absolute lg:inset-0 lg:h-full" loading="eager" />
    </div>
  </section>

  <!-- Applications -->
  <section class="bg-white section-lg px-4 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-7xl">
      <div class="mb-14 text-center">
        <h2 class="scroll-fade-up text-2xl font-medium text-mono-heading sm:text-3xl">{d.applications.title}</h2>
      </div>
      <div class="grid grid-cols-1 gap-y-10 gap-x-8 sm:grid-cols-2 lg:grid-cols-3">
        {d.applications.items.map((app, index) => (
          <div class={`scroll-fade-up stagger-${(index % 4) + 1} text-center`}>
            <Icon name={app.icon} class="mx-auto mb-4 h-8 w-8 text-mono-black" />
            <h3 class="text-mono-heading mb-2 text-base font-medium sm:text-lg">{app.title}</h3>
            <p class="mx-auto max-w-[240px] text-sm leading-relaxed text-mono-gray">{app.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Product -->
  <section class="bg-mono-lighter/50 section-lg px-4 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-7xl">
      <div class="grid grid-cols-1 items-center gap-12 lg:grid-cols-2">
        <div class="scroll-fade-up overflow-hidden rounded-2xl">
          <Image src={d.product.image} alt="Environmental remediation activated carbon" widths={[500, 800]} sizes="(max-width: 1024px) 100vw, 50vw" class="aspect-[5/6] w-full object-cover" />
        </div>
        <div class="scroll-fade-up">
          <h2 class="text-mono-heading mb-4 text-2xl font-medium sm:text-3xl">{d.product.title}</h2>
          <p class="text-mono-dark mb-8 text-base leading-relaxed sm:text-lg">{d.product.description}</p>
          <ul class="space-y-4">
            {d.product.highlights.map((item) => (
              <li class="flex items-start gap-3 text-sm leading-relaxed text-mono-dark sm:text-base">
                <Icon name="heroicons:check-circle-solid" class="mt-0.5 h-5 w-5 flex-shrink-0 text-mono-black" />
                {item}
              </li>
            ))}
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- Products -->
  <section class="bg-white section-lg px-4 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-7xl">
      <div class="mb-12 text-center">
        <h2 class="scroll-fade-up text-mono-heading text-2xl font-medium sm:text-3xl">{d.products.title}</h2>
      </div>
      <div class="scroll-fade-up">
        <div class="product-swiper overflow-hidden">
          <div class="swiper-wrapper">
            {d.products.items.map((product) => (
              <div class="swiper-slide">
                <div class="overflow-hidden rounded-xl border border-mono-lighter transition-all duration-300 hover:shadow-lg hover:border-mono-black/10">
                  <Image src={product.image} alt={product.name} widths={[300, 500]} sizes="(max-width: 640px) 100vw, (max-width: 1024px) 50vw, 33vw" class="aspect-video w-full object-cover" />
                  <div class="p-5">
                    <h3 class="text-mono-heading mb-2 text-base font-medium">{product.name}</h3>
                    <p class="text-mono-black/60 mb-2 text-xs font-medium">{product.info}</p>
                    <p class="text-mono-dark text-sm leading-relaxed">{product.description}</p>
                  </div>
                </div>
              </div>
            ))}
          </div>
        </div>
        <div class="mt-8 flex items-center justify-center gap-4">
          <button class="product-prev flex h-12 w-12 items-center justify-center rounded-full border-2 border-mono-black/15 bg-white text-mono-heading transition-all hover:bg-mono-lighter hover:border-mono-black/30 active:scale-95">
            <Icon name="heroicons:arrow-left" class="h-5 w-5" />
          </button>
          <button class="product-next group flex h-12 w-12 items-center justify-center rounded-full border-2 border-mono-black/15 text-mono-heading transition-all hover:bg-mono-lighter hover:border-mono-black/30 active:scale-95 animate-[btn-pulse_2s_ease-in-out_3]">
            <Icon name="heroicons:arrow-right" class="h-5 w-5" />
          </button>
        </div>
      </div>
    </div>
  </section>

  <script>
    import Swiper from 'swiper';
    import { Navigation } from 'swiper/modules';
    import 'swiper/css';

    new Swiper('.product-swiper', {
      modules: [Navigation],
      slidesPerView: 1.2,
      spaceBetween: 16,
      navigation: {
        prevEl: '.product-prev',
        nextEl: '.product-next',
      },
      breakpoints: {
        640: { slidesPerView: 2, spaceBetween: 20 },
        1024: { slidesPerView: 3, spaceBetween: 24 },
      },
    });
  </script>

  <style>
    @keyframes btn-pulse {
      0%, 100% { background-color: #ffffff; }
      50% { background-color: #E8F0FE; }
    }
  </style>

  <!-- Capabilities -->
  <section class="bg-mono-lighter/50 section-lg px-4 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-7xl">
      <div class="grid grid-cols-1 items-start gap-12 lg:grid-cols-[2fr_3fr]">
        <div class="scroll-fade-up lg:sticky lg:top-32">
          <h2 class="text-mono-heading mb-4 text-2xl font-medium sm:text-3xl">{d.capabilities.title}</h2>
          <p class="text-mono-dark text-base leading-relaxed sm:text-lg">
            {d.capabilities.subtitle}
          </p>
        </div>
        <div class="grid grid-cols-1 gap-5 sm:grid-cols-2">
          {d.capabilities.items.map((item, index) => (
            <div class={`scroll-fade-up stagger-${(index % 4) + 1} rounded-xl border border-mono-lighter bg-white p-6`}>
              <Icon name={item.icon} class="mb-3 h-6 w-6 text-mono-black" />
              <h3 class="text-mono-heading mb-2 text-base font-medium">{item.title}</h3>
              <p class="text-mono-gray text-sm leading-relaxed">{item.description}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <PageCTA
    title={d.cta.title}
    description={d.cta.description}
    buttonText={d.cta.buttonText}
    buttonHref={d.cta.buttonHref}
    bgImage={d.cta.bgImage}
  />
  <Footer config={homeConfig} />
</BaseLayout>
