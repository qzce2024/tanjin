---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { homeConfig } from '../../content/home/config';
import Navigation from '../../components/Navigation.astro';
import Footer from '../../components/Footer.astro';
import { Image } from 'astro:assets';
import { Icon } from 'astro-icon/components';
import postsData from '../../lib/posts-data.json';
import { postImages } from '../../lib/post-images';

export async function getStaticPaths() {
  return postsData.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
const title = post.title.rendered;
const content = post.content.rendered;
const postImage = postImages[post.slug];
const date = new Date(post.date).toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric'
});

// 提取目录（TOC）
const headings = [];
const headingRegex = /<h2[^>]*>(.*?)<\/h2>/g;
let match;
let index = 0;
while ((match = headingRegex.exec(content)) !== null) {
  const text = match[1].replace(/<[^>]*>/g, '');
  const id = `heading-${index}`;
  headings.push({ text, id });
  index++;
}

// 为内容中的h2添加id
let contentWithIds = content;
index = 0;
contentWithIds = contentWithIds.replace(/<h2([^>]*)>/g, () => {
  const id = `heading-${index}`;
  index++;
  return `<h2 id="${id}">`;
});

// 获取相关文章（最新的3篇，排除当前文章）
const relatedPosts = postsData.filter(p => p.slug !== post.slug).slice(0, 3);
---

<BaseLayout title={`${title} - Tanjin Carbon`} description={post.excerpt.rendered.replace(/<[^>]*>/g, '').substring(0, 160)}>
  <Navigation config={homeConfig} />

  <!-- Schema.org structured data -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": title,
    "datePublished": post.date,
    "dateModified": post.modified || post.date,
    "author": {
      "@type": "Organization",
      "name": "Tanjin Carbon"
    },
    "publisher": {
      "@type": "Organization",
      "name": "Tanjin Carbon",
      "logo": {
        "@type": "ImageObject",
        "url": "https://tanjincarbon.com/logo.png"
      }
    },
    "image": postImage ? `https://tanjincarbon.com${postImage.src}` : "",
    "description": post.excerpt.rendered.replace(/<[^>]*>/g, '').substring(0, 160)
  })} />

  <!-- Hero -->
  <section class="relative py-12 px-4 sm:px-6 lg:px-8" style="background-color: #F5F5F5;">
    <div class="mx-auto max-w-7xl">
      <!-- Breadcrumb -->
      <nav class="mb-6 flex items-center gap-2 text-sm text-gray-600 max-w-full overflow-hidden whitespace-nowrap">
        <a href="/" class="hover:text-mono-black shrink-0">Home</a>
        <span class="shrink-0">/</span>
        <a href="/blog" class="hover:text-mono-black shrink-0">Blog</a>
        <span class="shrink-0">/</span>
        <span class="text-gray-400 truncate">{title}</span>
      </nav>

      <div class="max-w-3xl">
        <h1 class="text-3xl font-bold text-mono-heading sm:text-4xl lg:text-5xl">{title}</h1>

        <!-- Meta info -->
        <div class="mt-4 flex items-center gap-4 text-sm text-gray-600">
          <div class="flex items-center gap-2">
            <div class="h-10 w-10 rounded-full bg-mono-black flex items-center justify-center text-white font-semibold">
              TC
            </div>
            <div>
              <p class="font-medium text-gray-900">Tanjin Carbon</p>
              <p class="text-xs">Technical Team</p>
            </div>
          </div>
          <span class="text-gray-400">•</span>
          <time>{date}</time>
        </div>
      </div>
    </div>
  </section>

  <!-- Content + Inquiry Form -->
  <section class="bg-white py-16 px-4 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-7xl">
      <div class="grid grid-cols-1 gap-12 lg:grid-cols-[2fr_1fr]">
        <!-- Left: Content -->
        <article>
          {postImage && (
            <Image src={postImage} alt={title} widths={[800, 1200]} sizes="(max-width: 1024px) 100vw, 66vw" class="mb-8 w-full rounded-lg" />
          )}
          <div class="prose-content" set:html={contentWithIds} />

          <!-- Social Share & CTA -->
          <div class="mt-12 border-t border-gray-200 pt-8">
            <div class="flex items-center justify-between">
              <div>
                <p class="text-sm font-medium text-gray-700 mb-2">Share this article</p>
                <div class="flex gap-3">
                  <a href={`https://twitter.com/intent/tweet?url=${encodeURIComponent('https://tanjincarbon.com/blog/' + post.slug)}&text=${encodeURIComponent(title)}`} target="_blank" class="flex h-10 w-10 items-center justify-center rounded-full bg-gray-100 text-gray-600 hover:bg-mono-black hover:text-white transition-colors">
                    <Icon name="simple-icons:x" class="h-5 w-5" />
                  </a>
                  <a href={`https://www.linkedin.com/sharing/share-offsite/?url=${encodeURIComponent('https://tanjincarbon.com/blog/' + post.slug)}`} target="_blank" class="flex h-10 w-10 items-center justify-center rounded-full bg-gray-100 text-gray-600 hover:bg-mono-black hover:text-white transition-colors">
                    <Icon name="simple-icons:linkedin" class="h-5 w-5" />
                  </a>
                  <a href={`https://www.facebook.com/sharer/sharer.php?u=${encodeURIComponent('https://tanjincarbon.com/blog/' + post.slug)}`} target="_blank" class="flex h-10 w-10 items-center justify-center rounded-full bg-gray-100 text-gray-600 hover:bg-mono-black hover:text-white transition-colors">
                    <Icon name="simple-icons:facebook" class="h-5 w-5" />
                  </a>
                </div>
              </div>
            </div>

          </div>
        </article>

        <!-- Right: Sidebar -->
        <div class="space-y-6">
          <!-- Table of Contents -->
          {headings.length > 0 && (
            <div class="rounded-lg border border-gray-200 bg-white p-6">
              <h3 class="mb-4 text-lg font-semibold text-mono-heading">Table of Contents</h3>
              <nav class="space-y-2">
                {headings.map((heading) => (
                  <a href={`#${heading.id}`} class="block text-sm text-gray-600 hover:text-mono-black transition-colors">
                    {heading.text}
                  </a>
                ))}
              </nav>
            </div>
          )}

          <!-- Inquiry Form -->
          <div class="lg:sticky lg:top-24">
            <div class="rounded-lg border border-gray-200 bg-gray-50 p-6">
            <h3 class="mb-4 text-lg font-semibold text-mono-heading">Get a Quote</h3>
            <form class="space-y-4">
              <div>
                <label class="mb-1 block text-sm font-medium text-gray-700">Name</label>
                <input type="text" required class="w-full rounded border border-gray-300 px-3 py-2 focus:border-mono-black focus:outline-none" />
              </div>
              <div>
                <label class="mb-1 block text-sm font-medium text-gray-700">Email <span class="text-red-500">*</span></label>
                <input type="email" required class="w-full rounded border border-gray-300 px-3 py-2 focus:border-mono-black focus:outline-none" />
              </div>
              <div>
                <label class="mb-1 block text-sm font-medium text-gray-700">Phone</label>
                <input type="tel" class="w-full rounded border border-gray-300 px-3 py-2 focus:border-mono-black focus:outline-none" />
              </div>
              <div>
                <label class="mb-1 block text-sm font-medium text-gray-700">Message <span class="text-red-500">*</span></label>
                <textarea rows="4" required class="w-full resize-none rounded border border-gray-300 px-3 py-2 focus:border-mono-black focus:outline-none"></textarea>
              </div>
              <button type="submit" class="w-full rounded-lg bg-mono-black py-3 font-semibold text-white transition-colors hover:bg-gray-800">
                Send Inquiry
              </button>
            </form>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Related Posts -->
  {relatedPosts.length > 0 && (
    <section class="bg-gray-50 py-16 px-4 sm:px-6 lg:px-8">
      <div class="mx-auto max-w-7xl">
        <h2 class="mb-8 text-2xl font-bold text-mono-heading">Related Articles</h2>
        <div class="grid grid-cols-1 gap-6 md:grid-cols-3">
          {relatedPosts.map((relatedPost) => {
            const relatedImage = postImages[relatedPost.slug];
            const excerpt = relatedPost.excerpt.rendered.replace(/<[^>]*>/g, '').substring(0, 100);
            return (
              <article class="group overflow-hidden rounded-lg border border-gray-200 bg-white transition-shadow hover:shadow-lg">
                {relatedImage && (
                  <a href={`/blog/${relatedPost.slug}`}>
                    <Image src={relatedImage} alt={relatedPost.title.rendered} widths={[400]} sizes="33vw" class="h-40 w-full object-cover transition-transform group-hover:scale-105" />
                  </a>
                )}
                <div class="p-4">
                  <h3 class="text-lg font-semibold text-mono-heading">
                    <a href={`/blog/${relatedPost.slug}`} class="hover:text-mono-black">
                      {relatedPost.title.rendered}
                    </a>
                  </h3>
                  <p class="mt-2 text-sm text-gray-600">{excerpt}...</p>
                </div>
              </article>
            );
          })}
        </div>
      </div>
    </section>
  )}

  <Footer config={homeConfig} />
</BaseLayout>

<style is:global>
  .prose-content h2 {
    font-size: 1.5rem;
    font-weight: 700;
    color: #0F172A;
    margin-top: 2.5rem;
    margin-bottom: 1rem;
    padding-bottom: 0.5rem;
    border-bottom: 2px solid #E8F0FE;
  }
  .prose-content h3 {
    font-size: 1.25rem;
    font-weight: 600;
    color: #1F2937;
    margin-top: 2rem;
    margin-bottom: 0.75rem;
  }
  .prose-content p {
    margin-bottom: 1.25rem;
    line-height: 1.8;
    color: #4B5563;
    font-size: 1.0625rem;
  }
  .prose-content ul {
    list-style: none;
    margin-bottom: 1.25rem;
    padding-left: 0;
  }
  .prose-content ol {
    margin-bottom: 1.25rem;
    padding-left: 1.5rem;
  }
  .prose-content ol li::marker {
    color: #0072EE;
    font-weight: 600;
  }
  .prose-content ul li {
    position: relative;
    padding-left: 1.5rem;
    margin-bottom: 0;
    color: #4B5563;
    line-height: 1.8;
    font-size: 1.0625rem;
  }
  .prose-content ul li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0.65em;
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background-color: #0072EE;
  }
  .prose-content ol li {
    margin-bottom: 0;
    color: #4B5563;
    line-height: 1.8;
    font-size: 1.0625rem;
  }
  .prose-content strong {
    color: #0F172A;
    font-weight: 600;
  }
  .prose-content a {
    color: #0072EE;
    text-decoration: underline;
    text-underline-offset: 2px;
    transition: color 200ms ease;
  }
  .prose-content a:hover {
    color: #0059BB;
  }
  .prose-content blockquote {
    border-left: 4px solid #0072EE;
    padding: 1rem 1.5rem;
    margin: 1.5rem 0;
    background-color: #F8FAFC;
    border-radius: 0 0.5rem 0.5rem 0;
    color: #334155;
    font-style: italic;
  }
  .prose-content blockquote p {
    margin-bottom: 0;
  }
  .prose-content img {
    max-width: 100%;
    height: auto;
    border-radius: 0.5rem;
    margin: 1.5rem 0;
  }
  .prose-content table {
    width: 100%;
    border-collapse: collapse;
    margin: 1.5rem 0;
    font-size: 0.9375rem;
  }
  .prose-content th {
    background-color: #F0F6FF;
    color: #0F172A;
    font-weight: 600;
    text-align: left;
    padding: 0.75rem 1rem;
    border-bottom: 2px solid #0072EE;
  }
  .prose-content td {
    padding: 0.75rem 1rem;
    border-bottom: 1px solid #E5E7EB;
    color: #4B5563;
  }
  .prose-content tr:hover td {
    background-color: #F8FAFC;
  }
</style>
