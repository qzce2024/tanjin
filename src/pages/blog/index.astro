---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { homeConfig } from '../../content/home/config';
import Navigation from '../../components/Navigation.astro';
import Footer from '../../components/Footer.astro';
import { Image } from 'astro:assets';
import blogHeroBg from '../../assets/images/blog/blog-hero.png';
import postsData from '../../lib/posts-data.json';
import { postImages } from '../../lib/post-images';

const posts = postsData;
---

<BaseLayout title="Blog - Tanjin Carbon" description="Latest news and insights about activated carbon">
  <Navigation config={homeConfig} />

  <!-- Hero -->
  <section class="section-lg relative overflow-hidden px-4 sm:px-6 lg:px-8">
    <Image
      src={blogHeroBg}
      alt=""
      widths={[800, 1200, 1920]}
      sizes="100vw"
      class="absolute inset-0 h-full w-full object-cover"
      loading="eager"
    />
    <div class="absolute inset-0 bg-gradient-to-br from-black/80 via-black/65 to-black/75"></div>
    <div class="relative mx-auto max-w-4xl text-center">
      <h1 class="fade-up mb-4 text-3xl font-medium text-white sm:text-4xl lg:text-5xl">
        Blog & Insights
      </h1>
      <p class="fade-up mx-auto max-w-2xl text-base leading-relaxed text-white/85 sm:text-lg lg:text-xl" style="animation-delay: 100ms">
        Latest news, technical guides, and industry insights about activated carbon
      </p>
    </div>
  </section>

  <!-- Blog Grid -->
  <section class="bg-white py-16 px-4 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-7xl">

      <div class="grid grid-cols-1 gap-8 md:grid-cols-2 lg:grid-cols-3">
        {posts.map((post) => {
          const postImage = postImages[post.slug];
          const excerpt = post.excerpt.rendered.replace(/<[^>]*>/g, '').substring(0, 150);
          const date = new Date(post.date).toLocaleDateString('en-US', {
            year: 'numeric',
            month: 'long',
            day: 'numeric'
          });

          return (
            <article class="group overflow-hidden rounded-lg border border-gray-200 bg-white transition-shadow hover:shadow-lg">
              {postImage && (
                <a href={`/blog/${post.slug}`}>
                  <Image src={postImage} alt={post.title.rendered} widths={[400, 600]} sizes="(max-width: 768px) 100vw, 33vw" class="h-48 w-full object-cover transition-transform group-hover:scale-105" />
                </a>
              )}
              <div class="p-6">
                <time class="text-sm text-gray-500">{date}</time>
                <h2 class="mt-2 text-xl font-semibold text-mono-heading">
                  <a href={`/blog/${post.slug}`} class="hover:text-mono-black">
                    {post.title.rendered}
                  </a>
                </h2>
                <p class="mt-3 text-gray-600">{excerpt}...</p>
                <a href={`/blog/${post.slug}`} class="mt-4 inline-flex items-center text-sm font-medium text-mono-black hover:underline">
                  Read more →
                </a>
              </div>
            </article>
          );
        })}
      </div>
    </div>
  </section>

  <Footer config={homeConfig} />
</BaseLayout>
