---
import BaseLayout from '../layouts/BaseLayout.astro';
import { homeConfig } from '../content/home/config';
import { productCategories } from '../content/home/products';
import { applicationsData } from '../content/home/applications';
import { whyChooseUsData } from '../content/home/why-choose-us';
import { homeHowItWorksSteps } from '../content/home/how-it-works';
import { homeTestimonialsData, homeTrustLogos } from '../content/home/testimonials';
import { homeFaqItems } from '../content/home/faq';
import heroProductImage from '../assets/images/home/hero-product.png';

import Navigation from '../components/Navigation.astro';
import Hero from '../components/Hero.astro';
import TrustBar from '../components/TrustBar.astro';
import ProductCategories from '../components/ProductCategories.astro';
import Applications from '../components/Applications.astro';
import WhyChooseUs from '../components/WhyChooseUs.astro';
import HowItWorks from '../components/HowItWorks.astro';
import Testimonials from '../components/Testimonials.astro';
import FAQ from '../components/FAQ.astro';
import Contact from '../components/Contact.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout
  title={homeConfig.site.title}
  description={homeConfig.site.description}
  keywords={homeConfig.site.keywords}
  ogTitle={homeConfig.site.ogTitle}
  ogDescription={homeConfig.site.ogDescription}
  twitterCard={homeConfig.site.twitterCard}
  twitterTitle={homeConfig.site.twitterTitle}
  twitterDescription={homeConfig.site.twitterDescription}
>
  <Navigation config={homeConfig} />
  <Hero config={homeConfig} heroImage={heroProductImage} />
  <TrustBar logos={homeTrustLogos} />
  <ProductCategories
    title="Activated Carbon Products"
    subtitle="4 product lines covering 90% of industrial carbon applications — each backed by COA and free samples"
    products={productCategories}
  />
  <Applications
    title="Industry Applications"
    subtitle="Proven performance across 8 core industries, backed by lab data and client results"
    items={applicationsData}
  />
  <WhyChooseUs
    title="Why 500+ Companies Choose Tanjin Carbon"
    subtitle="We're not a trading company — we're the factory"
    items={whyChooseUsData}
  />
  <HowItWorks config={homeConfig} steps={homeHowItWorksSteps} />
  <Testimonials config={homeConfig} testimonials={homeTestimonialsData} />
  <FAQ config={homeConfig} items={homeFaqItems} />
  <Contact config={homeConfig} />
  <Footer config={homeConfig} />
</BaseLayout>
