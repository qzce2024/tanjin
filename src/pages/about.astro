---
import BaseLayout from '../layouts/BaseLayout.astro';
import { homeConfig } from '../content/home/config';
import { aboutData } from '../content/about';
import Navigation from '../components/Navigation.astro';
import PageCTA from '../components/PageCTA.astro';
import Footer from '../components/Footer.astro';
import { Icon } from 'astro-icon/components';
import { Image } from 'astro:assets';
import aboutHeroBg from '../assets/images/about/about-hero.png';
import aboutCtaBg from '../assets/images/about/about-cta.png';

const d = aboutData;
---

<BaseLayout
  title="About Us - Tanjin Carbon"
  description="Learn about Tanjin Carbon — 15+ years of activated carbon manufacturing experience, serving 500+ clients in 50+ countries."
>
  <Navigation config={homeConfig} />

  <!-- Hero -->
  <section class="relative overflow-hidden px-4 pt-32 pb-20 sm:px-6 lg:px-8">
    <Image src={aboutHeroBg} alt="" widths={[800, 1200, 1920]} sizes="100vw" class="absolute inset-0 h-full w-full object-cover" loading="eager" />
    <div class="absolute inset-0 bg-mono-heading/75"></div>
    <div class="relative mx-auto max-w-4xl text-center">
      <h1 class="scroll-fade-up mb-4 text-3xl font-extrabold text-white sm:text-4xl lg:text-5xl">About Tanjin Carbon</h1>
      <p class="scroll-fade-up mx-auto max-w-2xl text-base leading-relaxed text-white/85 sm:text-lg lg:text-xl">
        Factory-direct activated carbon manufacturer with 15+ years of experience serving global industries
      </p>
    </div>
  </section>

  <!-- Who We Are -->
  <section class="bg-white section-lg px-4 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-7xl">
      <div class="grid grid-cols-1 items-center gap-12 lg:grid-cols-2">
        <div>
          <h2 class="text-mono-heading mb-6 text-2xl font-bold sm:text-3xl">{d.intro.title}</h2>
          <p class="text-mono-dark mb-4 text-base leading-relaxed sm:text-lg">{d.intro.description}</p>
          <p class="text-mono-dark text-base leading-relaxed sm:text-lg">{d.intro.detail}</p>
        </div>
        <div class="overflow-hidden rounded-2xl">
          <Image src={d.intro.image} alt="Tanjin Carbon Factory" widths={[500, 800]} sizes="(max-width: 1024px) 100vw, 50vw" class="aspect-4/3 w-full object-cover" />
        </div>
      </div>
    </div>
  </section>

  <!-- Tagline -->
  <section class="bg-mono-heading section-sm px-4 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-4xl text-center">
      <p class="text-lg leading-relaxed text-white/90 italic sm:text-xl lg:text-2xl">
        "{d.tagline}"
      </p>
    </div>
  </section>

  <!-- Products / Quality / Team -->
  <section class="bg-mono-lighter section-lg px-4 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-7xl space-y-12">
      {d.sections.map((item) => (
        <div class="grid grid-cols-1 items-center gap-12 lg:grid-cols-[2fr_3fr]">
          <div class="overflow-hidden rounded-2xl">
            <Image src={item.image} alt={item.title} widths={[500, 800]} sizes="(max-width: 1024px) 100vw, 40vw" class="aspect-4/3 w-full object-cover" />
          </div>
          <div>
            <h3 class="text-mono-heading mb-4 text-2xl font-bold sm:text-3xl">{item.title}</h3>
            <p class="text-mono-dark mb-8 text-base leading-relaxed sm:text-lg">{item.description}</p>
            <a
              href={item.buttonHref}
              class="inline-flex items-center gap-2 rounded-lg bg-mono-black px-6 py-3 text-sm font-semibold text-white transition-colors hover:bg-mono-heading"
            >
              {item.buttonText}
              <Icon name="heroicons:arrow-right" class="h-4 w-4" />
            </a>
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- Why Choose Us -->
  <section class="bg-white section-lg px-4 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-7xl">
      <div class="mb-12 text-center">
        <h2 class="text-mono-heading mb-4 text-2xl font-bold sm:text-3xl">Why Choose Us</h2>
      </div>
      <div class="grid grid-cols-1 gap-8 sm:grid-cols-2 lg:grid-cols-4">
        {d.advantages.map((item) => (
          <div class="rounded-xl border border-mono-lighter p-6 text-center transition-shadow duration-200 hover:shadow-lg">
            <Icon name={item.icon} class="text-mono-black mx-auto mb-4 h-10 w-10" />
            <h3 class="text-mono-heading mb-2 text-lg font-bold">{item.title}</h3>
            <p class="text-mono-dark text-sm leading-relaxed">{item.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <PageCTA
    title="Ready to Work With Us?"
    description="Get factory-direct pricing, free samples, and expert consultation."
    buttonText="Get Free Samples"
    buttonHref="#inquiry"
    bgImage={aboutCtaBg}
  />
  <Footer config={homeConfig} />
</BaseLayout>
