---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { homeConfig } from '../../content/home/config';
import { coconutShellGranularData } from '../../content/products/coconut-shell-granular';
import Navigation from '../../components/Navigation.astro';
import Footer from '../../components/Footer.astro';
import { Image } from 'astro:assets';
import { Icon } from 'astro-icon/components';

const d = coconutShellGranularData;
---

<BaseLayout title={d.meta.title} description={d.meta.description}>
  <Navigation config={homeConfig} />

  <!-- Hero -->
  <section class="relative py-20 px-4 sm:px-6 lg:px-8" style="background-color: #F5F5F5; background-image: radial-gradient(circle at 1px 1px, rgba(0,0,0,0.03) 1px, transparent 0); background-size: 20px 20px;">
    <div class="mx-auto max-w-7xl">
      <div class="grid grid-cols-1 items-center gap-12 lg:grid-cols-[3fr_2fr]">
        <div>
          <h1 class="fade-up mb-6 text-3xl font-semibold leading-tight text-mono-heading sm:text-4xl lg:text-5xl">
            {d.title}
          </h1>
          <p class="fade-up mb-8 text-base leading-relaxed text-gray-700 sm:text-lg" style="animation-delay: 100ms">
            {d.description}
          </p>
          <div class="fade-up mb-10 space-y-3" style="animation-delay: 150ms">
            {d.hero.advantages.map((adv) => (
              <div class="flex items-center gap-3">
                <Icon name="heroicons:check" class="h-5 w-5 flex-shrink-0 text-mono-black font-bold" />
                <span class="text-gray-800 text-base font-medium">{adv}</span>
              </div>
            ))}
          </div>
          <button class="inquiry-trigger fade-up group inline-flex items-center gap-3 rounded-lg border-2 border-mono-black bg-mono-black px-8 py-3.5 text-base font-semibold text-white transition-all hover:bg-white hover:text-mono-black" style="animation-delay: 200ms">
            Request a Quote
            <Icon name="heroicons:arrow-right" class="h-5 w-5 transition-transform group-hover:translate-x-1" />
          </button>
        </div>
        <div class="fade-up" style="animation-delay: 250ms">
          <div class="w-full overflow-hidden rounded-lg shadow-xl lg:hidden" style="aspect-ratio: 16/9;">
            <Image src={d.hero.image} alt={d.hero.title} widths={[500, 800]} sizes="100vw" class="h-full w-full object-cover" style="display: block;" />
          </div>
          <div class="hidden w-full overflow-hidden rounded-lg shadow-xl lg:block" style="aspect-ratio: 4/3;">
            <Image src={d.hero.image} alt={d.hero.title} widths={[500, 800]} sizes="40vw" class="h-full w-full object-cover" style="display: block;" />
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Content + Inquiry Form -->
  <section class="bg-white py-16 px-4 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-7xl">
      <div class="grid grid-cols-1 gap-12 lg:grid-cols-[2fr_1fr]">
        <!-- Left: Content -->
        <div class="prose-content">
          <div set:html={d.content} />
        </div>

        <!-- Right: Specifications + Inquiry Form -->
        <div class="lg:sticky lg:top-24 lg:self-start space-y-6">
          <!-- Specifications Table -->
          <div class="rounded-lg border border-gray-200 bg-white p-6">
            <h3 class="mb-4 text-lg font-semibold text-mono-heading">Technical Specifications</h3>
            <table class="w-full">
              <tbody>
                {d.specifications.map((spec) => (
                  <tr class="border-b border-gray-200 last:border-0">
                    <td class="py-3 pr-4 text-sm font-medium text-gray-600">{spec.label}</td>
                    <td class="py-3 text-sm font-semibold text-mono-heading">{spec.value}</td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>

          <!-- Inquiry Form -->
          <div class="rounded-lg border border-gray-200 bg-gray-50 p-6">
            <h3 class="mb-4 text-lg font-semibold text-mono-heading">Request a Quote</h3>
            <form class="space-y-4">
              <div>
                <label class="mb-1 block text-sm font-medium text-gray-700">Name</label>
                <input type="text" required class="w-full rounded border border-gray-300 px-3 py-2 focus:border-mono-black focus:outline-none" />
              </div>
              <div>
                <label class="mb-1 block text-sm font-medium text-gray-700">Email</label>
                <input type="email" required class="w-full rounded border border-gray-300 px-3 py-2 focus:border-mono-black focus:outline-none" />
              </div>
              <div>
                <label class="mb-1 block text-sm font-medium text-gray-700">Company</label>
                <input type="text" class="w-full rounded border border-gray-300 px-3 py-2 focus:border-mono-black focus:outline-none" />
              </div>
              <div>
                <label class="mb-1 block text-sm font-medium text-gray-700">Message</label>
                <textarea rows="4" class="w-full resize-none rounded border border-gray-300 px-3 py-2 focus:border-mono-black focus:outline-none"></textarea>
              </div>
              <button type="submit" class="w-full rounded-lg bg-mono-black py-3 font-semibold text-white transition-colors hover:bg-gray-800">
                Send Inquiry
              </button>
            </form>
          </div>
        </div>
      </div>
    </div>
  </section>

  <Footer config={homeConfig} />
</BaseLayout>

<style>
  .prose-content h2 {
    font-size: 1.5rem;
    font-weight: 600;
    color: #0F172A;
    margin-bottom: 1rem;
    margin-top: 2rem;
  }
  .prose-content h2:first-child {
    margin-top: 0;
  }
  .prose-content p {
    margin-bottom: 1rem;
    line-height: 1.75;
    color: #374151;
  }
  .prose-content ul {
    margin-bottom: 1.5rem;
    list-style-type: disc;
    padding-left: 1.5rem;
  }
  .prose-content li {
    margin-bottom: 0.5rem;
    color: #374151;
  }
  .prose-content strong {
    font-weight: 600;
    color: #111827;
  }
</style>
