---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { homeConfig } from '../../content/home/config';
import { woodBasedData } from '../../content/products/wood-based';
import Navigation from '../../components/Navigation.astro';
import PageCTA from '../../components/PageCTA.astro';
import Footer from '../../components/Footer.astro';
import { Image } from 'astro:assets';
import { Icon } from 'astro-icon/components';

const d = woodBasedData;
---
<BaseLayout title={d.meta.title} description={d.meta.description}>
  <Navigation config={homeConfig} />

  <section class="relative overflow-hidden bg-[linear-gradient(135deg,#020202_0%,#0a0f14_34%,#111822_68%,#050607_100%)] px-4 pt-20 sm:px-6 lg:px-8" style="padding-bottom: 0;">
    <div class="absolute inset-0 bg-[radial-gradient(circle_at_top_left,rgba(255,255,255,0.10),transparent_30%),radial-gradient(circle_at_bottom_right,rgba(71,85,105,0.24),transparent_34%),linear-gradient(180deg,rgba(148,163,184,0.05),transparent_24%)]"></div>
    <div class="absolute inset-0 opacity-[0.08]" style="background-image: repeating-linear-gradient(135deg, rgba(226,232,240,0.22) 0, rgba(226,232,240,0.22) 1px, transparent 1px, transparent 14px);"></div>
    <div class="absolute inset-x-0 top-0 h-px bg-white/10"></div>
    <div class="relative z-10 mx-auto max-w-7xl pb-14 sm:pb-16 lg:pb-16">
      <div class="grid grid-cols-1 items-center gap-10 lg:grid-cols-[3fr_2fr] lg:gap-14 xl:gap-16">
        <div class="order-2 lg:order-1">
          {d.hero.tag && (
            <p class="scroll-fade-up mb-5 text-[11px] font-semibold tracking-[0.22em] text-white/70 uppercase">
              {d.hero.tag}
            </p>
          )}
          <h1 class="scroll-fade-up mb-5 text-3xl font-medium text-white sm:text-4xl lg:text-5xl">
            Wood-Based Activated Carbon Supplier & Manufacturer
          </h1>
          <p class="scroll-fade-up mb-7 text-[15px] leading-7 text-white/78 sm:text-base">
            {d.hero.description}
          </p>
          <ul class="scroll-fade-up mb-8 space-y-2 text-[14px] leading-6 text-white/88 sm:text-[15px]">
            {d.hero.highlights.map((item) => (
              <li class="flex items-center gap-3 border-b border-white/15 pb-2.5">
                <Icon name="heroicons:check" class="h-4 w-4 flex-shrink-0 text-white" />
                <span>{item}</span>
              </li>
            ))}
          </ul>
          <div class="scroll-fade-up">
            <button class="inquiry-trigger inline-flex items-center justify-center rounded-sm bg-mono-black px-5 py-3 text-sm font-semibold text-white shadow-lg shadow-black/25 transition-all hover:bg-mono-darker sm:px-6 sm:text-[15px]">
              {d.hero.buttonText}
            </button>
          </div>
        </div>

        <div class="order-1 flex items-center justify-center lg:order-2 lg:justify-center">
          <div class="aspect-[4/3] w-full overflow-hidden rounded-sm border border-white/10 bg-white/5 shadow-2xl shadow-black/30">
            <Image src={d.hero.bgImage} alt="Wood-based activated carbon powder for sugar decolorization and pharmaceutical purification" widths={[900, 1200, 1600]} sizes="(max-width: 1024px) 100vw, 40vw" class="h-full w-full object-cover object-center" loading="eager" />
          </div>
        </div>
      </div>
    </div>
  </section>

  <main class="bg-white">
    <section id="product-advantages" class="scroll-mt-32 bg-[#f8fafc] px-4 py-14 sm:px-6 sm:py-16 lg:px-8 lg:py-20">
      <div class="mx-auto max-w-5xl text-center">
        <h2 class="mb-4 text-2xl font-medium text-mono-heading sm:text-3xl">Why customers choose our supply</h2>
      </div>

      <div class="mx-auto mt-10 grid max-w-6xl grid-cols-1 gap-8 sm:grid-cols-2 lg:grid-cols-4">
        {d.whyChooseUs.items.slice(0, 4).map((item) => (
          <div class="flex flex-col items-center text-center">
            <Icon name={item.icon} class="mb-4 h-8 w-8 text-mono-black" />
            <h3 class="mb-2 text-sm font-medium text-mono-heading sm:text-base">{item.title}</h3>
            <p class="max-w-xs text-sm leading-6 text-mono-gray sm:text-[15px]">{item.description}</p>
          </div>
        ))}
      </div>
    </section>

    <section id="overview" class="scroll-mt-32 bg-white px-4 py-14 sm:px-6 sm:py-16 lg:px-8 lg:py-20">
      <div class="mx-auto grid max-w-7xl gap-10 lg:grid-cols-[1.05fr_0.95fr] lg:items-start">
        <div>
          <h2 class="mb-4 text-2xl font-medium text-mono-heading sm:text-3xl">Wood-based activated carbon product overview</h2>
          <div class="space-y-5 text-[15px] leading-8 text-mono-dark sm:text-base">
            <p>
              Wood-based activated carbon is a highly adsorptive material produced from selected wood raw materials. Its developed pore structure, strong decolorization performance, and relatively low ash content make it suitable for liquid-phase purification processes that require fast adsorption and effective color removal.
            </p>
            <p>
              As a supplier, we provide wood-based activated carbon mainly in powdered and specialty grades for food processing, pharmaceutical purification, amino acid production, and fine chemical treatment. Supply can be arranged for standard grades as well as custom specifications based on methylene blue value, particle size, ash content, moisture, and packing requirements.
            </p>
          </div>
        </div>

        <div>
          <div class="overflow-hidden rounded-sm border border-mono-lighter">
            <Image src={d.factoryShowcase.images[0].src} alt="Wood-based activated carbon production line and manufacturing facility" widths={[900, 1200, 1600]} sizes="(max-width: 1024px) 100vw, 45vw" class="aspect-[4/3] w-full object-cover" />
          </div>
        </div>
      </div>
    </section>

    <section id="product-forms" class="scroll-mt-32 bg-[#0a0f14] px-4 py-14 sm:px-6 sm:py-16 lg:px-8 lg:py-20">
      <div class="mx-auto max-w-7xl">
        <div class="mb-8 max-w-4xl">
          <h2 class="mb-4 text-2xl font-medium text-white sm:text-3xl">Technical Parameters</h2>
          <p class="text-[15px] leading-8 text-white/75 sm:text-base">
            The table below shows common particle sizes and key technical parameters for wood-based activated carbon supply, including mesh range, methylene blue value, moisture, and core product characteristics.
          </p>
        </div>

        <div id="specifications" class="overflow-x-auto rounded-sm border border-white/10 bg-[#111822]">
          <table class="min-w-full text-left text-[14px] sm:text-[15px]">
            <thead>
              <tr class="border-b border-white/10 text-white/60">
                <th class="w-[30%] py-3 pl-4 pr-4 font-semibold">Parameter</th>
                <th class="w-[70%] py-3 pr-4 font-semibold">Value</th>
              </tr>
            </thead>
            <tbody class="text-white/80">
              <tr class="border-b border-white/10 align-top">
                <td class="py-4 pl-4 pr-4 font-semibold text-white">Particle Size</td>
                <td class="py-4 pr-4">
                  <div class="grid gap-x-8 gap-y-2 sm:grid-cols-3">
                    <div class="space-y-2">
                      <div>100 mesh</div>
                      <div>200 mesh</div>
                      <div>325 mesh</div>
                    </div>
                    <div class="space-y-2">
                      <div>200–325 mesh</div>
                      <div>-325 mesh</div>
                      <div>Fine powder grades</div>
                    </div>
                    <div class="space-y-2">
                      <div>Food-grade powder</div>
                      <div>Pharmaceutical grade</div>
                      <div>Custom sizes available</div>
                    </div>
                  </div>
                </td>
              </tr>
              <tr class="border-b border-white/10 align-top">
                <td class="py-4 pl-4 pr-4 font-semibold text-white">Methylene Blue Value</td>
                <td class="py-4 pr-4">150–240 mg/g</td>
              </tr>
              <tr class="border-b border-white/10 align-top">
                <td class="py-4 pl-4 pr-4 font-semibold text-white">Moisture</td>
                <td class="py-4 pr-4">≤10%</td>
              </tr>
              <tr class="border-b border-white/10 align-top">
                <td class="py-4 pl-4 pr-4 font-semibold text-white">Characteristics</td>
                <td class="py-4 pr-4">Strong decolorization, developed mesopore structure, low ash, rapid adsorption</td>
              </tr>
            </tbody>
          </table>
        </div>
      </div>
    </section>

    <section id="applications" class="scroll-mt-32 bg-[#f8fafc] px-4 py-14 sm:px-6 sm:py-16 lg:px-8 lg:py-20">
      <div class="mx-auto max-w-7xl">
        <div class="mb-8 max-w-4xl">
          <h2 class="mb-4 text-2xl font-medium text-mono-heading sm:text-3xl">Typical Applications</h2>
          <p class="text-[15px] leading-8 text-mono-dark sm:text-base">
            Typical applications include sugar decolorization, starch and glucose purification, pharmaceutical purification, food additive processing, amino acid production, and other liquid-phase adsorption systems.
          </p>
        </div>

        <div class="grid gap-3 sm:grid-cols-2 xl:grid-cols-3">
          {d.typicalApplications.map((item) => (
            <div class="flex items-start gap-3 border-b border-mono-lighter pb-3 text-[14px] leading-6 text-mono-dark sm:text-[15px] last:border-b-0 last:pb-0">
              <Icon name="heroicons:check" class="mt-1 h-4 w-4 flex-shrink-0 text-mono-black" />
              <span>{item}</span>
            </div>
          ))}
        </div>
      </div>
    </section>

    <section id="packaging-supply" class="scroll-mt-32 bg-white px-4 py-14 sm:px-6 sm:py-16 lg:px-8 lg:py-20">
      <div class="mx-auto grid max-w-7xl gap-8 lg:grid-cols-[1.05fr_0.95fr] lg:items-start">
        <div>
          <h2 class="mb-5 text-2xl font-medium text-mono-heading sm:text-3xl">Packaging and shipping</h2>
          <p class="mb-6 text-[15px] leading-8 text-mono-dark sm:text-base">
            Standard export packaging with complete documentation support. All shipments include quality certificates and can be arranged for container or LCL delivery.
          </p>
          <div class="space-y-3 text-[14px] leading-7 text-mono-dark sm:text-[15px]">
            <div class="border-b border-mono-lighter pb-3"><strong class="text-mono-heading">Packaging:</strong> 20 kg bag</div>
            <div class="border-b border-mono-lighter pb-3"><strong class="text-mono-heading">Lead time:</strong> 15–20 days after order confirmation</div>
            <div class="border-b border-mono-lighter pb-3"><strong class="text-mono-heading">Certifications:</strong> NSF, HALAL, KOSHER</div>
            <div class="border-b border-mono-lighter pb-3"><strong class="text-mono-heading">Shipping from:</strong> Fujian Province, China</div>
          </div>
          <div class="mt-6">
            <button class="inquiry-trigger inline-flex items-center justify-center rounded-sm bg-mono-black px-5 py-3 text-sm font-semibold text-white shadow-lg shadow-black/25 transition-all hover:bg-mono-darker sm:px-6 sm:text-[15px]">
              Request a Quote
            </button>
          </div>
        </div>

        <div>
          <div class="grid grid-cols-2 gap-[3px] overflow-hidden rounded-sm border border-mono-lighter bg-mono-lighter/20">
            {d.factoryShowcase.images.slice(0, 4).map((img, index) => (
              <div class="overflow-hidden bg-white">
                <Image
                  src={img.src}
                  alt={`Wood-based activated carbon ${['production facility', 'quality control lab', 'warehouse storage', 'export packaging'][index]}`}
                  widths={[300, 500]}
                  sizes="(max-width: 1024px) 50vw, 24vw"
                  class="aspect-[4/3] w-full object-cover"
                />
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>

    <section id="faq" class="scroll-mt-32 bg-[#f8fafc] px-4 py-14 sm:px-6 sm:py-16 lg:px-8 lg:py-20">
      <div class="mx-auto max-w-4xl">
        <div class="mb-10 text-center">
          <h2 class="mb-4 text-2xl font-medium text-mono-heading sm:text-3xl">Frequently asked questions</h2>
        </div>
        <div class="space-y-4">
          {d.faq.map((item) => (
            <details class="group rounded-sm border border-mono-lighter bg-white">
              <summary class="flex cursor-pointer items-center justify-between px-5 py-4 text-left font-semibold text-mono-heading transition-colors hover:bg-mono-black hover:text-white">
                <span class="pr-4 text-[15px] sm:text-base">{item.question}</span>
                <svg class="h-5 w-5 flex-shrink-0 text-mono-gray transition-transform group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
                </svg>
              </summary>
              <div class="px-5 pb-4">
                <p class="text-[15px] leading-7 text-mono-dark">{item.answer}</p>
              </div>
            </details>
          ))}
        </div>
      </div>
    </section>
  </main>

  <PageCTA
    title={d.cta.title}
    description={d.cta.description}
    buttonText={d.cta.buttonText}
    buttonHref={d.cta.buttonHref}
    bgImage={d.cta.bgImage}
  />
  <Footer config={homeConfig} />
</BaseLayout>
