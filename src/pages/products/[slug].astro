---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { homeConfig } from '../../content/home/config';
import Navigation from '../../components/Navigation.astro';
import Footer from '../../components/Footer.astro';
import { Icon } from 'astro-icon/components';
import { Image } from 'astro:assets';
import { productImages } from '../../lib/product-images';
import productsData from '../../lib/products-data.json';

export async function getStaticPaths() {
  return productsData.map((product) => ({
    params: { slug: product.slug },
    props: { product },
  }));
}

const { product } = Astro.props;
const title = product.title.rendered;
const description = product.acf?.introduction || product.excerpt.rendered.replace(/<[^>]*>/g, '').substring(0, 160);
const content = product.content.rendered;

// 使用映射的本地图片
const productImage = productImages[product.slug];

const advantages = [
  'Global shipping with stable supply chain',
  'Factory-direct competitive pricing',
  'Custom specifications available',
];
---

<BaseLayout title={`${title} - Tanjin Carbon`} description={description}>
  <Navigation config={homeConfig} />

  <!-- Hero -->
  <section class="relative py-14 px-4 sm:px-6 lg:px-8" style="background-color: #F5F5F5; background-image: radial-gradient(circle at 1px 1px, rgba(0,0,0,0.03) 1px, transparent 0); background-size: 20px 20px;">
    <div class="mx-auto max-w-7xl">
      <div class="grid grid-cols-1 items-center gap-10 lg:grid-cols-[3fr_2fr]">
        <div>
          <h1 class="fade-up mb-4 text-3xl font-semibold leading-tight text-mono-heading sm:text-4xl sm:leading-tight lg:text-5xl lg:leading-tight">
            {title}
          </h1>
          <p class="fade-up mb-6 text-base leading-relaxed text-gray-700 sm:text-lg" style="animation-delay: 100ms">
            {description}
          </p>
          <div class="fade-up mb-7 space-y-2.5" style="animation-delay: 150ms">
            {advantages.map((adv) => (
              <div class="flex items-center gap-3">
                <Icon name="heroicons:check" class="h-5 w-5 flex-shrink-0 text-mono-black font-bold" />
                <span class="text-gray-800 text-base font-medium">{adv}</span>
              </div>
            ))}
          </div>
          <button class="inquiry-trigger fade-up group inline-flex items-center gap-3 rounded-lg border-2 border-mono-black bg-mono-black px-8 py-3.5 text-base font-semibold text-white transition-all hover:bg-white hover:text-mono-black" style="animation-delay: 200ms">
            Request a Quote
            <Icon name="heroicons:arrow-right" class="h-5 w-5 transition-transform group-hover:translate-x-1" />
          </button>
        </div>
        {productImage && (
          <div class="fade-up" style="animation-delay: 250ms">
            <div class="w-full overflow-hidden rounded-lg shadow-xl lg:hidden" style="aspect-ratio: 16/9;">
              <Image src={productImage} alt={title} widths={[500, 800]} sizes="100vw" class="h-full w-full object-cover" />
            </div>
            <div class="hidden w-full overflow-hidden rounded-lg shadow-xl lg:block" style="aspect-ratio: 4/3;">
              <Image src={productImage} alt={title} widths={[500, 800]} sizes="40vw" class="h-full w-full object-cover" />
            </div>
          </div>
        )}
      </div>
    </div>
  </section>

  <!-- Content + Inquiry Form -->
  <section class="bg-white py-16 px-4 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-7xl">
      <div class="grid grid-cols-1 gap-12 lg:grid-cols-[2fr_1fr]">
        <!-- Left: Content -->
        <div class="prose-content">
          <div set:html={content} />
        </div>

        <!-- Right: Inquiry Form -->
        <div class="lg:sticky lg:top-24 lg:self-start">
          <div class="rounded-lg border border-gray-200 bg-gray-50 p-6">
            <h3 class="mb-4 text-lg font-semibold text-mono-heading">Request a Quote</h3>
            <form class="space-y-4">
              <div>
                <label class="mb-1 block text-sm font-medium text-gray-700">Name</label>
                <input type="text" required class="w-full rounded border border-gray-300 px-3 py-2 focus:border-mono-black focus:outline-none" />
              </div>
              <div>
                <label class="mb-1 block text-sm font-medium text-gray-700">Email <span class="text-red-500">*</span></label>
                <input type="email" required class="w-full rounded border border-gray-300 px-3 py-2 focus:border-mono-black focus:outline-none" />
              </div>
              <div>
                <label class="mb-1 block text-sm font-medium text-gray-700">Phone</label>
                <input type="tel" class="w-full rounded border border-gray-300 px-3 py-2 focus:border-mono-black focus:outline-none" />
              </div>
              <div>
                <label class="mb-1 block text-sm font-medium text-gray-700">Message <span class="text-red-500">*</span></label>
                <textarea rows="4" required class="w-full resize-none rounded border border-gray-300 px-3 py-2 focus:border-mono-black focus:outline-none"></textarea>
              </div>
              <button type="submit" class="w-full rounded-lg bg-mono-black py-3 font-semibold text-white transition-colors hover:bg-gray-800">
                Send Inquiry
              </button>
            </form>
          </div>
        </div>
      </div>
    </div>
  </section>

  <Footer config={homeConfig} />
</BaseLayout>

<style is:global>
  .prose-content h2 {
    font-size: 1.375rem;
    font-weight: 600;
    color: #0F172A;
    margin-top: 2rem;
    margin-bottom: 1rem;
    padding-bottom: 0.75rem;
    border-bottom: 1px solid #D1D5DB;
  }
  .prose-content h2:first-child {
    margin-top: 0;
  }
  .prose-content h3 {
    font-size: 1.125rem;
    font-weight: 600;
    color: #1F2937;
    margin-top: 1.5rem;
    margin-bottom: 0.75rem;
  }
  .prose-content p {
    margin-bottom: 1rem;
    line-height: 1.7;
    color: #4B5563;
    font-size: 0.95rem;
  }
  .prose-content ul, .prose-content ol {
    margin-bottom: 1.25rem;
    padding-left: 1.5rem;
  }
  .prose-content ul {
    list-style-type: disc;
  }
  .prose-content ol {
    list-style-type: decimal;
  }
  .prose-content li {
    margin-bottom: 0.5rem;
    color: #4B5563;
    font-size: 0.95rem;
    line-height: 1.7;
  }
  .prose-content strong {
    font-weight: 600;
    color: #1F2937;
  }
  .prose-content table {
    width: 100%;
    margin: 1.5rem 0;
    border-collapse: collapse;
    background: #FAFBFC;
    border-radius: 0.375rem;
    overflow: hidden;
    border: 1px solid #E5E7EB;
  }
  .prose-content table tr {
    border-bottom: 1px solid #E5E7EB;
  }
  .prose-content table tr:last-child {
    border-bottom: none;
  }
  .prose-content table td, .prose-content table th {
    padding: 0.875rem 1rem;
    font-size: 0.9rem;
    text-align: left;
  }
  .prose-content table th {
    font-weight: 600;
    color: #1F2937;
    background: #F3F4F6;
  }
  .prose-content table td {
    color: #4B5563;
  }
  .prose-content figure {
    margin: 1.5rem 0;
  }
  .prose-content img {
    max-width: 100%;
    height: auto;
    border-radius: 0.375rem;
  }
</style>

