---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { homeConfig } from '../../content/home/config';
import { coconutShellData } from '../../content/products/coconut-shell';
import Navigation from '../../components/Navigation.astro';
import TrustBar from '../../components/TrustBar.astro';
import PageCTA from '../../components/PageCTA.astro';
import WhyChooseUs from '../../components/WhyChooseUs.astro';
import Footer from '../../components/Footer.astro';
import { Image } from 'astro:assets';
import { Icon } from 'astro-icon/components';

import { whyChooseUsData } from '../../content/home/why-choose-us';

const d = coconutShellData;
---

<BaseLayout title={d.meta.title} description={d.meta.description}>
  <Navigation config={homeConfig} />

  <!-- Hero -->
  <section class="px-4 sm:px-6 lg:px-8" style="padding-top: calc(5rem + 4.5rem); padding-bottom: 0; background: radial-gradient(ellipse at center, #FFFFFF 0%, #E8EFF9 55%, #D6E4F5 100%);">
    <div class="mx-auto max-w-7xl">
      <div class="grid grid-cols-1 items-center gap-10 lg:grid-cols-2 lg:gap-16">
        <!-- Left: Content -->
        <div>
          <h1 class="scroll-fade-up mb-5 text-3xl font-bold text-mono-heading sm:text-4xl lg:text-5xl lg:leading-tight">
            {d.hero.title}
          </h1>
          <p class="scroll-fade-up mb-6 text-base leading-relaxed text-mono-dark/70 sm:text-lg">
            {d.hero.description}
          </p>
          <ul class="scroll-fade-up mb-8 space-y-2.5">
            {d.hero.highlights.map((item) => (
              <li class="flex items-center text-sm text-mono-dark sm:text-base">
                <Icon name="heroicons:check" class="mr-2.5 h-5 w-5 flex-shrink-0 text-mono-black" />
                {item}
              </li>
            ))}
          </ul>
          <div class="scroll-fade-up">
            <button class="inquiry-trigger group inline-flex items-center gap-2 rounded-lg bg-mono-black px-7 py-3.5 text-sm font-semibold text-white shadow-lg transition-all hover:bg-mono-darker sm:text-base">
              {d.hero.buttonText}
              <Icon name="heroicons:arrow-right" class="h-4 w-4 transition-transform group-hover:translate-x-1" />
            </button>
          </div>
        </div>
        <!-- Right: Image -->
        <div>
          <Image src={d.hero.bgImage} alt="Coconut shell activated carbon" widths={[500, 800]} sizes="(max-width: 1024px) 100vw, 50vw" class="aspect-[4/3] w-full rounded-2xl object-cover shadow-lg" loading="eager" />
        </div>
      </div>
      <!-- Stats bar -->
      <div class="mt-14 grid grid-cols-2 gap-4 pb-14 sm:grid-cols-4 sm:pb-20">
        {d.hero.stats.map((stat) => (
          <div class="scroll-fade-up rounded-xl bg-white px-4 py-6 text-center shadow-sm transition-all duration-200 hover:shadow-md hover:-translate-y-1">
            <p class="text-2xl font-bold text-mono-heading sm:text-3xl">{stat.value}</p>
            <p class="mt-1 text-xs font-medium text-mono-gray sm:text-sm">{stat.label}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Product Types -->
  <section class="bg-white section-lg px-4 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-7xl">
      <div class="scroll-fade-up mx-auto mb-12 max-w-3xl text-center">
        <h2 class="text-mono-heading mb-3 text-2xl font-bold sm:text-3xl">{d.productTypes.title}</h2>
        <p class="text-mono-dark text-base sm:text-lg">{d.productTypes.subtitle}</p>
      </div>

      <!-- Tabs -->
      <div class="scroll-fade-up mb-6 flex flex-wrap justify-center gap-2">
        {d.productTypes.items.map((item, index) => (
          <button
            class={`product-tab rounded-full px-5 py-2 text-sm font-medium transition-all ${index === 0 ? 'bg-mono-black text-white' : 'bg-mono-lighter/50 text-mono-dark hover:bg-mono-lighter'}`}
            data-tab={index}
          >
            {item.tab}
          </button>
        ))}
      </div>

      <!-- Tab Panels -->
      {d.productTypes.items.map((item, index) => (
        <div class={`product-panel ${index === 0 ? '' : 'hidden'}`} data-panel={index}>
          <div class="grid grid-cols-1 items-start gap-10 bg-mono-lighter p-6 sm:p-8 lg:grid-cols-[2fr_3fr]">
            <!-- Image -->
            <div class="overflow-hidden rounded-2xl">
              <Image src={item.image} alt={item.title} widths={[500, 800]} sizes="(max-width: 1024px) 100vw, 40vw" class="aspect-[4/3] w-full object-cover" />
            </div>
            <!-- Content -->
            <div>
              <h3 class="text-mono-heading mb-3 text-xl font-bold sm:text-2xl">{item.title}</h3>
              <p class="text-mono-dark/70 mb-5 text-sm leading-relaxed sm:text-base">{item.description}</p>
              <ul class="mb-6 space-y-1.5">
                {item.applications.map((app) => (
                  <li class="flex items-center text-sm text-mono-dark">
                    <Icon name="heroicons:check" class="mr-2 h-4 w-4 flex-shrink-0 text-mono-black" />
                    {app}
                  </li>
                ))}
              </ul>
              <button class="inquiry-trigger group inline-flex items-center gap-2 rounded-lg bg-mono-black px-6 py-3 text-sm font-semibold text-white transition-all hover:bg-mono-darker" data-product={`Inquiry about: ${item.title}`}>
                Get a Quote
                <Icon name="heroicons:arrow-right" class="h-4 w-4 transition-transform group-hover:translate-x-1" />
              </button>
            </div>
          </div>
        </div>
      ))}
    </div>
  </section>

  <script>
    document.querySelectorAll('.product-tab').forEach((tab) => {
      tab.addEventListener('click', () => {
        const index = tab.getAttribute('data-tab');
        document.querySelectorAll('.product-tab').forEach((t) => {
          t.classList.remove('bg-mono-black', 'text-white');
          t.classList.add('bg-mono-lighter/50', 'text-mono-dark');
        });
        tab.classList.remove('bg-mono-lighter/50', 'text-mono-dark');
        tab.classList.add('bg-mono-black', 'text-white');
        document.querySelectorAll('.product-panel').forEach((p) => p.classList.add('hidden'));
        document.querySelector(`.product-panel[data-panel="${index}"]`)?.classList.remove('hidden');
      });
    });
  </script>

  <!-- What We Offer -->
  <section class="bg-mono-lighter/30 section-lg px-4 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-7xl">
      <div class="scroll-fade-up mx-auto mb-12 max-w-3xl text-center">
        <h2 class="text-mono-heading mb-3 text-2xl font-bold sm:text-3xl">{d.whatWeOffer.title}</h2>
        <p class="text-mono-dark text-base sm:text-lg">{d.whatWeOffer.subtitle}</p>
      </div>
      <div class="grid grid-cols-1 gap-5 sm:grid-cols-2 lg:grid-cols-3">
        {d.whatWeOffer.items.map((item, index) => (
          <div class={`scroll-fade-up stagger-${(index % 4) + 1} rounded-xl border border-mono-lighter bg-white p-6 transition-shadow duration-200 hover:shadow-lg`}>
            <Icon name={item.icon} class="mb-3 h-7 w-7 text-mono-black" />
            <h3 class="text-mono-heading mb-1.5 text-base font-bold">{item.title}</h3>
            <p class="text-mono-gray text-sm leading-relaxed">{item.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Why Choose Us -->
  <section class="bg-white section-lg px-4 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-7xl">
      <div class="scroll-fade-up mx-auto mb-12 max-w-3xl text-center">
        <h2 class="text-mono-heading mb-3 text-2xl font-bold sm:text-3xl">{d.whyChooseUs.title}</h2>
      </div>
      <div class="grid grid-cols-1 gap-5 sm:grid-cols-2 lg:grid-cols-3">
        {d.whyChooseUs.items.map((item, index) => (
          <div class={`scroll-fade-up stagger-${(index % 4) + 1} flex items-start gap-4 rounded-xl border border-mono-lighter p-5`}>
            <Icon name={item.icon} class="mt-0.5 h-6 w-6 flex-shrink-0 text-mono-black" />
            <div>
              <h3 class="text-mono-heading mb-1 text-sm font-bold">{item.title}</h3>
              <p class="text-mono-gray text-sm leading-relaxed">{item.description}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Factory Showcase -->
  <section class="bg-mono-lighter/30 section-lg px-4 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-7xl">
      <div class="scroll-fade-up mx-auto mb-12 max-w-3xl text-center">
        <h2 class="text-mono-heading mb-3 text-2xl font-bold sm:text-3xl">{d.factoryShowcase.title}</h2>
        <p class="text-mono-dark text-base sm:text-lg">{d.factoryShowcase.subtitle}</p>
      </div>
      <div class="grid grid-cols-1 gap-10 lg:grid-cols-[3fr_2fr]">
        <!-- Images -->
        <div class="scroll-fade-up grid grid-cols-2 gap-3">
          {d.factoryShowcase.images.map((img) => (
            <div class="group overflow-hidden rounded-xl">
              <Image src={img.src} alt={img.alt} widths={[300, 500]} sizes="(max-width: 1024px) 50vw, 30vw" class="aspect-[4/3] w-full object-cover transition-transform duration-300 group-hover:scale-105" />
              <p class="mt-2 text-center text-xs text-mono-gray">{img.caption}</p>
            </div>
          ))}
        </div>
        <!-- Highlights -->
        <div class="scroll-fade-up flex flex-col justify-center">
          <ul class="space-y-4">
            {d.factoryShowcase.highlights.map((point) => (
              <li class="flex items-start gap-3 text-sm text-mono-dark sm:text-base">
                <Icon name="heroicons:check-circle-solid" class="mt-0.5 h-5 w-5 flex-shrink-0 text-mono-black" />
                {point}
              </li>
            ))}
          </ul>
          <div class="mt-8">
            <a href="/about" class="inline-flex items-center gap-2 text-sm font-semibold text-mono-black hover:text-mono-darker">
              Learn more about our factory
              <Icon name="heroicons:arrow-right" class="h-4 w-4" />
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- How to Order -->
  <section class="bg-white section-lg px-4 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-7xl">
      <div class="scroll-fade-up mx-auto mb-12 max-w-3xl text-center">
        <h2 class="text-mono-heading mb-3 text-2xl font-bold sm:text-3xl">{d.orderProcess.title}</h2>
        <p class="text-mono-dark text-base sm:text-lg">{d.orderProcess.subtitle}</p>
      </div>
      <div class="scroll-fade-up grid grid-cols-2 gap-6 sm:grid-cols-3 lg:grid-cols-5">
        {d.orderProcess.steps.map((s, index) => (
          <div class={`text-center stagger-${index + 1}`}>
            <div class="mx-auto mb-3 flex h-14 w-14 items-center justify-center rounded-full bg-mono-black text-lg font-bold text-white">
              {s.step}
            </div>
            <h3 class="text-mono-heading mb-1 text-sm font-bold">{s.title}</h3>
            <p class="text-xs leading-snug text-mono-dark">{s.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="bg-white section-lg px-4 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-3xl">
      <div class="scroll-fade-up mb-12 text-center">
        <h2 class="text-mono-heading mb-3 text-2xl font-bold sm:text-3xl">Frequently Asked Questions</h2>
      </div>
      <div class="scroll-fade-up divide-y divide-mono-lighter rounded-xl border border-mono-lighter">
        {d.faq.map((item) => (
          <div>
            <button class="faq-button flex w-full items-center justify-between px-6 py-4 text-left" aria-expanded="false">
              <span class="text-mono-heading pr-4 text-sm font-semibold sm:text-base">{item.question}</span>
              <Icon name="heroicons:chevron-down" class="faq-icon h-5 w-5 flex-shrink-0 text-mono-gray transition-transform duration-200" />
            </button>
            <div class="faq-content px-6">
              <p class="text-mono-dark text-sm leading-relaxed">{item.answer}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <script>
    document.querySelectorAll('.faq-button').forEach((btn) => {
      btn.addEventListener('click', () => {
        const expanded = btn.getAttribute('aria-expanded') === 'true';
        btn.setAttribute('aria-expanded', String(!expanded));
        const content = btn.nextElementSibling as HTMLElement;
        content?.classList.toggle('active');
        const icon = btn.querySelector('.faq-icon') as HTMLElement;
        icon?.classList.toggle('rotate-180');
      });
    });
  </script>

  <!-- CTA -->
  <PageCTA
    title={d.cta.title}
    description={d.cta.description}
    buttonText={d.cta.buttonText}
    buttonHref={d.cta.buttonHref}
    bgImage={d.cta.bgImage}
  />
  <Footer config={homeConfig} />
</BaseLayout>
