---
import BaseLayout from '../layouts/BaseLayout.astro';
import { homeConfig } from '../content/home/config';
import { contactPageData } from '../content/contact-page';
import Navigation from '../components/Navigation.astro';
import Footer from '../components/Footer.astro';
import { Icon } from 'astro-icon/components';
import { Image } from 'astro:assets';
import contactHeroBg from '../assets/images/contact/contact-hero.png';
---

<BaseLayout
  title="Contact Us - Tanjin Carbon"
  description="Get in touch with Tanjin Carbon. Request a quote, free samples, or technical consultation for activated carbon products."
>
  <Navigation config={homeConfig} />

  <!-- Hero with background image -->
  <section class="relative overflow-hidden px-4 pt-20 pb-20 sm:px-6 lg:px-8">
    <Image
      src={contactHeroBg}
      alt=""
      widths={[800, 1200, 1920]}
      sizes="100vw"
      class="absolute inset-0 h-full w-full object-cover"
      loading="eager"
    />
    <div class="absolute inset-0 bg-mono-heading/75"></div>
    <div class="relative mx-auto max-w-4xl text-center">
      <h1 class="fade-up mb-4 text-3xl font-medium text-white sm:text-4xl lg:text-5xl">
        Get in Touch
      </h1>
      <p class="fade-up mx-auto max-w-2xl text-base leading-relaxed text-white/85 sm:text-lg lg:text-xl" style="animation-delay: 100ms">
        Request a quote, free samples, or technical consultation — we respond within 24 hours
      </p>
    </div>
  </section>

  <!-- Contact: Info Left + Form Right -->
  <section class="section-lg px-4 sm:px-6 lg:px-8" style="background-color: #F5F5F5;">
    <div class="mx-auto max-w-7xl">
      <div class="grid grid-cols-1 items-start gap-12 lg:grid-cols-2">
        <!-- Left: Info -->
        <div class="scroll-fade-up">
          <h2 class="text-mono-heading mb-4 text-2xl font-medium leading-tight sm:text-3xl lg:text-4xl">
            Get Your Custom Quote
          </h2>
          <p class="text-mono-dark mb-10 text-base leading-relaxed sm:text-lg">
            Get the right carbon grade, pricing, and samples — all in one conversation. No back-and-forth with middlemen.
          </p>

          <div class="space-y-6">
            {contactPageData.info.map((item) => (
              <div class="flex items-start gap-4">
                <div class="bg-mono-black/10 flex h-10 w-10 flex-shrink-0 items-center justify-center rounded-lg">
                  <Icon name={item.icon} class="text-mono-black h-5 w-5" />
                </div>
                <div>
                  <h3 class="text-mono-heading text-sm font-medium">{item.title}</h3>
                  {item.lines.map((line) =>
                    item.href ? (
                      <a href={item.href} class="text-mono-black text-sm font-medium hover:underline">{line}</a>
                    ) : (
                      <p class="text-mono-dark text-sm">{line}</p>
                    )
                  )}
                </div>
              </div>
            ))}
          </div>
        </div>

        <!-- Right: Form -->
        <div class="scroll-fade-up stagger-2 rounded-2xl p-6 shadow-xl sm:p-8" style="background-color: #FAFAFA;">
          <form id="contactForm" action="https://api.web3forms.com/submit" method="POST" class="space-y-5">
            <input type="hidden" name="access_key" value="fa886cef-962b-44d9-a0c6-f86678b0c2cc" />
            <input type="hidden" name="subject" value="New Inquiry from Tanjin Carbon Website" />
            <input type="hidden" name="from_name" value="Tanjin Carbon Website" />
            <input type="checkbox" name="botcheck" class="hidden" style="display:none" />
            <input type="hidden" name="IP Address" id="hiddenIp" value="" />
            <input type="hidden" name="Country" id="hiddenCountry" value="" />
            <input type="hidden" name="Browser" id="hiddenBrowser" value="" />
            <input type="hidden" name="Language" id="hiddenLang" value="" />
            <input type="hidden" name="Page URL" id="hiddenPage" value="" />
            <input type="hidden" name="Screen Size" id="hiddenScreen" value="" />
            <input type="hidden" name="Timezone" id="hiddenTimezone" value="" />
            <div>
              <label for="name" class="text-mono-heading mb-2 block text-sm font-semibold">{homeConfig.contact.form.fields.name.label}</label>
              <input type="text" id="name" name="name" required class="w-full rounded-lg border-2 border-gray-300 px-4 py-3 transition-all duration-200 focus:border-mono-black" placeholder={homeConfig.contact.form.fields.name.placeholder} />
            </div>
            <div>
              <label for="email" class="text-mono-heading mb-2 block text-sm font-semibold">{homeConfig.contact.form.fields.email.label}</label>
              <input type="email" id="email" name="email" required class="w-full rounded-lg border-2 border-gray-300 px-4 py-3 transition-all duration-200 focus:border-mono-black" placeholder={homeConfig.contact.form.fields.email.placeholder} />
            </div>
            <div>
              <label for="company" class="text-mono-heading mb-2 block text-sm font-semibold">{homeConfig.contact.form.fields.company.label}</label>
              <input type="text" id="company" name="company" class="w-full rounded-lg border-2 border-gray-300 px-4 py-3 transition-all duration-200 focus:border-mono-black" placeholder={homeConfig.contact.form.fields.company.placeholder} />
            </div>
            <div>
              <label for="message" class="text-mono-heading mb-2 block text-sm font-semibold">{homeConfig.contact.form.fields.message.label}</label>
              <textarea id="message" name="message" rows="4" class="w-full resize-none rounded-lg border-2 border-gray-300 px-4 py-3 transition-all duration-200 focus:border-mono-black" placeholder={homeConfig.contact.form.fields.message.placeholder}></textarea>
            </div>
            <div id="formSuccess" class="hidden rounded-lg bg-green-50 p-4 text-center text-sm font-medium text-green-700">
              Thank you! We'll get back to you within 24 hours.
            </div>
            <div id="formError" class="hidden rounded-lg bg-red-50 p-4 text-center text-sm font-medium text-red-700">
              Something went wrong. Please try again or email us directly.
            </div>
            <button type="submit" id="submitBtn" class="bg-mono-black w-full rounded-lg px-6 py-4 font-semibold text-white shadow-lg transition-all duration-200 hover:shadow-xl">
              {homeConfig.contact.form.cta}
            </button>
            <p class="text-mono-gray text-center text-xs leading-relaxed">
              By submitting this form, you agree to our
              <a href="#" class="underline">Terms of Service</a> and
              <a href="#" class="underline">Privacy Policy</a>
            </p>
          </form>
        </div>
      </div>
    </div>
  </section>

  <Footer config={homeConfig} />
</BaseLayout>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const form = document.getElementById('contactForm') as HTMLFormElement;
    const submitBtn = document.getElementById('submitBtn') as HTMLButtonElement;
    const successMsg = document.getElementById('formSuccess')!;
    const errorMsg = document.getElementById('formError')!;
    const btnText = submitBtn.textContent || '';

    (document.getElementById('hiddenBrowser') as HTMLInputElement).value = navigator.userAgent;
    (document.getElementById('hiddenLang') as HTMLInputElement).value = navigator.language;
    (document.getElementById('hiddenPage') as HTMLInputElement).value = window.location.href;
    (document.getElementById('hiddenScreen') as HTMLInputElement).value = `${screen.width}x${screen.height}`;
    (document.getElementById('hiddenTimezone') as HTMLInputElement).value = Intl.DateTimeFormat().resolvedOptions().timeZone;

    if (!(window as any).__ipDataPromise) {
      (window as any).__ipDataPromise = fetch('https://ipapi.co/json/')
        .then(r => r.json())
        .catch(() => null);
    }
    (window as any).__ipDataPromise.then((ipData: any) => {
      if (!ipData) return;
      (document.getElementById('hiddenIp') as HTMLInputElement).value = ipData.ip || '';
      (document.getElementById('hiddenCountry') as HTMLInputElement).value = `${ipData.country_name || ''} (${ipData.city || ''})`;
    });

    if (form) {
      form.addEventListener('submit', async (e) => {
        e.preventDefault();
        submitBtn.disabled = true;
        submitBtn.textContent = 'Sending...';
        successMsg.classList.add('hidden');
        errorMsg.classList.add('hidden');

        try {
          const res = await fetch(form.action, {
            method: 'POST',
            body: new FormData(form),
          });
          const data = await res.json();

          if (data.success) {
            successMsg.classList.remove('hidden');
            form.reset();
          } else {
            errorMsg.classList.remove('hidden');
          }
        } catch {
          errorMsg.classList.remove('hidden');
        } finally {
          submitBtn.disabled = false;
          submitBtn.textContent = btnText;
        }
      });
    }
  });
</script>
