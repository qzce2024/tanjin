---
import BaseLayout from '../layouts/BaseLayout.astro';
import { homeConfig } from '../content/home/config';
import { productsHero, productsTrustItems, materialCards, formItems, featuredProducts, orderSteps, productFaq } from '../content/products-page';
import Navigation from '../components/Navigation.astro';
import TrustBar from '../components/TrustBar.astro';
import PageCTA from '../components/PageCTA.astro';
import Footer from '../components/Footer.astro';
import { Image } from 'astro:assets';
import { Icon } from 'astro-icon/components';
import heroBg from '../assets/images/applications/activated-carbon-applications.png';
import ctaBg from '../assets/images/applications/activated-carbon-inquiry.png';
---

<BaseLayout
  title="Products - Tanjin Carbon"
  description="Explore our full range of activated carbon products: coconut shell, wood-based, and coal-based carbon in granular, powdered, columnar, honeycomb, and pelletized forms."
>
  <Navigation config={homeConfig} />

  <!-- 1. Hero -->
  <section class="relative flex min-h-screen items-center overflow-hidden px-4 sm:px-6 lg:px-8">
    <Image src={heroBg} alt="" widths={[800, 1200, 1920]} sizes="100vw" class="absolute inset-0 h-full w-full object-cover" loading="eager" />
    <div class="absolute inset-0 bg-mono-heading/75"></div>
    <div class="relative mx-auto w-full max-w-7xl py-32">
      <div class="max-w-xl">
        <h1 class="scroll-fade-up mb-6 text-3xl font-extrabold leading-tight text-white sm:text-4xl lg:text-5xl">
          {productsHero.title}
        </h1>
        <p class="scroll-fade-up mb-8 text-base leading-relaxed text-white/80 sm:text-lg">
          {productsHero.subtitle}
        </p>
        <ul class="scroll-fade-up mb-10 space-y-3">
          {productsHero.highlights.map((h) => (
            <li class="flex items-center text-sm text-white/90 sm:text-base">
              <Icon name="heroicons:check-circle-solid" class="mr-2.5 h-5 w-5 flex-shrink-0 text-mono-black" />
              {h}
            </li>
          ))}
        </ul>
        <div class="scroll-fade-up flex flex-wrap gap-4">
          <button class="inquiry-trigger rounded-lg bg-mono-black px-7 py-3 text-sm font-semibold text-white shadow-lg transition-all hover:bg-mono-darker sm:text-base">
            Request a Quote
          </button>
          <a href="#products" class="rounded-lg border-2 border-white/40 bg-white/10 px-7 py-3 text-sm font-semibold text-white backdrop-blur-sm transition-all hover:border-white/60 hover:bg-white/20 sm:text-base">
            Browse Products
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- 2. TrustBar -->
  <TrustBar logos={productsTrustItems} />

  <!-- 3. Featured Products -->
  <section id="products" class="bg-white section-lg px-4 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-7xl">
      <div class="scroll-fade-up mx-auto mb-12 max-w-3xl text-center">
        <h2 class="text-mono-heading mb-3 text-2xl font-bold sm:text-3xl lg:text-4xl">Featured Export Products</h2>
        <p class="text-mono-dark text-base sm:text-lg">Our most popular activated carbon grades for global markets</p>
      </div>

      <div class="grid grid-cols-1 gap-8 sm:grid-cols-2 lg:grid-cols-3">
        {featuredProducts.map((product, index) => (
          <div class={`scroll-fade-up group overflow-hidden rounded-xl border border-mono-lighter card-hover stagger-${index + 1}`}>
            <div class="aspect-[3/2] overflow-hidden">
              <Image
                src={product.image}
                alt={product.name}
                widths={[400, 600]}
                sizes="(max-width: 640px) 100vw, (max-width: 1024px) 50vw, 33vw"
                class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-105"
              />
            </div>
            <div class="p-6">
              <span class="mb-2 inline-block rounded-full bg-mono-lighter px-3 py-1 text-xs font-bold text-mono-black">{product.model}</span>
              <h3 class="text-mono-heading mb-2 text-lg font-bold">{product.name}</h3>
              <p class="text-mono-dark mb-4 text-sm leading-relaxed">{product.description}</p>
              <button class="inquiry-trigger rounded-lg bg-mono-black px-5 py-2.5 text-sm font-semibold text-white" data-product={`Inquiry about: ${product.model} - ${product.name}`}>
                Get Quote
              </button>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- 4. Materials + Forms -->
  <section class="bg-mono-lighter/30 section-lg px-4 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-7xl">
      <!-- Materials -->
      <div class="scroll-fade-up mx-auto mb-10 max-w-3xl text-center">
        <h2 class="text-mono-heading mb-3 text-2xl font-bold sm:text-3xl lg:text-4xl">Browse by Material</h2>
        <p class="text-mono-dark text-base sm:text-lg">Each raw material offers unique pore structures and adsorption characteristics</p>
      </div>

      <div class="grid grid-cols-1 gap-6 sm:grid-cols-3 mb-16">
        {materialCards.map((card, index) => (
          <div class={`scroll-fade-up flex items-start gap-4 rounded-xl bg-white p-5 border border-mono-lighter stagger-${index + 1}`}>
            <div class="h-16 w-16 flex-shrink-0 overflow-hidden rounded-lg">
              <Image src={card.image} alt={card.title} widths={[128]} sizes="64px" class="h-full w-full object-cover" />
            </div>
            <div>
              <h3 class="text-mono-heading mb-1 text-sm font-bold">{card.title}</h3>
              <p class="text-mono-dark text-xs leading-relaxed">{card.description}</p>
            </div>
          </div>
        ))}
      </div>

      <!-- Forms -->
      <div class="scroll-fade-up mx-auto mb-8 max-w-3xl text-center">
        <h3 class="text-mono-heading mb-3 text-xl font-bold sm:text-2xl">Available Product Forms</h3>
        <p class="text-mono-dark text-sm sm:text-base">Select the right physical form for your process requirements</p>
      </div>

      <div class="scroll-fade-up flex flex-wrap justify-center gap-3">
        {formItems.map((item) => (
          <span class="inline-flex items-center gap-2 rounded-full border border-mono-lighter bg-white px-5 py-2.5 text-sm font-medium text-mono-heading transition-colors hover:border-mono-black/20 hover:bg-mono-lighter">
            <Icon name={item.icon} class="h-4 w-4 text-mono-black" />
            {item.title}
          </span>
        ))}
      </div>
    </div>
  </section>

  <!-- 5. Custom Manufacturing + Global Logistics -->
  <section class="bg-mono-heading section-lg px-4 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-7xl">
      <div class="grid grid-cols-1 gap-12 lg:grid-cols-2">
        <!-- Custom Manufacturing -->
        <div class="scroll-fade-up">
          <h2 class="mb-4 text-2xl font-bold text-white sm:text-3xl">Custom Manufacturing & OEM</h2>
          <p class="mb-6 text-base leading-relaxed text-white/70">
            Need a specific iodine value, particle size, or impregnation type? Our in-house R&D team and flexible production lines can develop custom formulations tailored to your exact process requirements.
          </p>
          <ul class="space-y-3">
            <li class="flex items-start text-sm text-white/80">
              <Icon name="heroicons:check-circle" class="mr-2 mt-0.5 h-5 w-5 flex-shrink-0 text-mono-black" />
              <span>Custom iodine values, CTC, and methylene blue specifications</span>
            </li>
            <li class="flex items-start text-sm text-white/80">
              <Icon name="heroicons:check-circle" class="mr-2 mt-0.5 h-5 w-5 flex-shrink-0 text-mono-black" />
              <span>Private labeling and OEM packaging available</span>
            </li>
            <li class="flex items-start text-sm text-white/80">
              <Icon name="heroicons:check-circle" class="mr-2 mt-0.5 h-5 w-5 flex-shrink-0 text-mono-black" />
              <span>Dedicated project manager for custom orders</span>
            </li>
          </ul>
        </div>

        <!-- Global Logistics -->
        <div class="scroll-fade-up stagger-2">
          <h2 class="mb-4 text-2xl font-bold text-white sm:text-3xl">Secure Global Logistics</h2>
          <p class="mb-6 text-base leading-relaxed text-white/70">
            From our factory floor to your facility — we handle packaging, documentation, and shipping to ensure your activated carbon arrives safely and on time.
          </p>
          <ul class="space-y-3">
            <li class="flex items-start text-sm text-white/80">
              <Icon name="heroicons:check-circle" class="mr-2 mt-0.5 h-5 w-5 flex-shrink-0 text-mono-black" />
              <span>25 kg bags, 500 kg super sacks, or custom packaging</span>
            </li>
            <li class="flex items-start text-sm text-white/80">
              <Icon name="heroicons:check-circle" class="mr-2 mt-0.5 h-5 w-5 flex-shrink-0 text-mono-black" />
              <span>FOB, CIF, and DDP shipping terms available</span>
            </li>
            <li class="flex items-start text-sm text-white/80">
              <Icon name="heroicons:check-circle" class="mr-2 mt-0.5 h-5 w-5 flex-shrink-0 text-mono-black" />
              <span>Exported to 50+ countries across 6 continents</span>
            </li>
            <li class="flex items-start text-sm text-white/80">
              <Icon name="heroicons:check-circle" class="mr-2 mt-0.5 h-5 w-5 flex-shrink-0 text-mono-black" />
              <span>Full export documentation: COA, MSDS, Bill of Lading</span>
            </li>
          </ul>
        </div>
      </div>

      <!-- Centered CTA -->
      <div class="scroll-fade-up mt-12 text-center">
        <button class="inquiry-trigger rounded-lg bg-white px-8 py-3.5 text-sm font-semibold text-mono-heading shadow-lg transition-all hover:bg-mono-lighter sm:text-base" data-product="Custom Manufacturing Inquiry">
          Discuss Your Requirements
        </button>
      </div>
    </div>
  </section>

  <!-- 6. How to Order + FAQ -->
  <section class="bg-white section-lg px-4 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-7xl">
      <!-- How to Order -->
      <div class="scroll-fade-up mx-auto mb-12 max-w-3xl text-center">
        <h2 class="text-mono-heading mb-3 text-2xl font-bold sm:text-3xl lg:text-4xl">How to Order</h2>
        <p class="text-mono-dark text-base sm:text-lg">From inquiry to delivery in 5 simple steps</p>
      </div>

      <div class="grid grid-cols-2 gap-6 sm:grid-cols-3 lg:grid-cols-5 mb-16">
        {orderSteps.map((s, index) => (
          <div class={`scroll-fade-up text-center stagger-${index + 1}`}>
            <div class="mx-auto mb-3 flex h-14 w-14 items-center justify-center rounded-full bg-mono-black text-lg font-bold text-white">
              {s.step}
            </div>
            <h3 class="text-mono-heading mb-1 text-sm font-bold">{s.title}</h3>
            <p class="text-xs leading-snug text-mono-dark">{s.description}</p>
          </div>
        ))}
      </div>

      <!-- Divider -->
      <div class="mx-auto mb-16 max-w-3xl border-t border-mono-lighter"></div>

      <!-- FAQ -->
      <div class="mx-auto max-w-3xl">
        <div class="scroll-fade-up mb-12 text-center">
          <h2 class="text-mono-heading mb-3 text-2xl font-bold sm:text-3xl lg:text-4xl">Commercial FAQ</h2>
          <p class="text-mono-dark text-base sm:text-lg">Common questions about ordering, pricing, and logistics</p>
        </div>

        <div class="scroll-fade-up divide-y divide-mono-lighter rounded-xl border border-mono-lighter">
          {productFaq.map((item) => (
            <div>
              <button class="faq-button flex w-full items-center justify-between px-6 py-4 text-left" aria-expanded="false">
                <span class="text-mono-heading pr-4 text-sm font-semibold sm:text-base">{item.question}</span>
                <Icon name="heroicons:chevron-down" class="faq-icon h-5 w-5 flex-shrink-0 text-mono-gray" />
              </button>
              <div class="faq-content px-6">
                <p class="text-mono-dark text-sm leading-relaxed">{item.answer}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- 7. PageCTA + Footer -->
  <PageCTA
    title="Ready to Get Started?"
    description="Share your application details and our engineers will recommend the optimal product type, form, and specification."
    buttonText="Request a Quote"
    buttonHref="#inquiry"
    bgImage={ctaBg}
  />
  <Footer config={homeConfig} />
</BaseLayout>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    document.querySelectorAll('.faq-button').forEach((btn) => {
      btn.addEventListener('click', () => {
        const expanded = btn.getAttribute('aria-expanded') === 'true';
        btn.setAttribute('aria-expanded', String(!expanded));
        const content = btn.nextElementSibling as HTMLElement;
        content?.classList.toggle('active');
      });
    });
  });
</script>
