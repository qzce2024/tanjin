---
import BaseLayout from '../layouts/BaseLayout.astro';
import { homeConfig } from '../content/home/config';
import { productsHero, productMaterials } from '../content/products-page';
import Navigation from '../components/Navigation.astro';
import PageCTA from '../components/PageCTA.astro';
import Footer from '../components/Footer.astro';
import MaterialSection from '../components/MaterialSection.astro';
import { Image } from 'astro:assets';
import heroBg from '../assets/images/applications/activated-carbon-applications.png';
import ctaBg from '../assets/images/applications/activated-carbon-inquiry.png';
---

<BaseLayout
  title="Products - Tanjin Carbon"
  description="Explore our full range of activated carbon products organized by coconut shell, wood-based, and coal-based material families for water, air, food, mining, and industrial applications."
>
  <Navigation config={homeConfig} />

  <section class="relative overflow-hidden px-4 pt-32 pb-20 sm:px-6 lg:px-8">
    <Image
      src={heroBg}
      alt=""
      widths={[800, 1200, 1920]}
      sizes="100vw"
      class="absolute inset-0 h-full w-full object-cover"
      loading="eager"
    />
    <div class="absolute inset-0 bg-mono-heading/75"></div>
    <div class="relative mx-auto max-w-4xl text-center">
      <h1 class="fade-up mb-4 text-3xl font-bold text-white sm:text-4xl lg:text-5xl">
        {productsHero.title}
      </h1>
      <p class="fade-up mx-auto max-w-2xl text-base leading-relaxed text-white/85 sm:text-lg lg:text-xl" style="animation-delay: 100ms">
        {productsHero.subtitle}
      </p>
    </div>
  </section>

  <section id="products" class="bg-white">
    {productMaterials.map((material, index) => (
      <div class={material.id === 'wood' ? 'bg-mono-lighter/35' : index % 2 === 1 ? 'bg-mono-lighter/20' : 'bg-white'}>
        <MaterialSection {...material} />
      </div>
    ))}
  </section>

  <PageCTA
    title="Ready to Get Started?"
    description="Share your application details and our engineers will recommend the right material family, product form, and export specification."
    buttonText="Request a Quote"
    buttonHref="#inquiry"
    bgImage={ctaBg}
  />
  <Footer config={homeConfig} />
</BaseLayout>
