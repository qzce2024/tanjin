---
import BaseLayout from '../layouts/BaseLayout.astro';
import { homeConfig } from '../content/home/config';
import { faqPageData } from '../content/faq-page';
import Navigation from '../components/Navigation.astro';
import PageCTA from '../components/PageCTA.astro';
import Footer from '../components/Footer.astro';
import { Icon } from 'astro-icon/components';
import { Image } from 'astro:assets';
import faqHeroBg from '../assets/images/faq/faq-hero.png';
import faqCtaBg from '../assets/images/faq/faq-cta.png';
---

<BaseLayout
  title="FAQ - Tanjin Carbon"
  description="Frequently asked questions about Tanjin Carbon activated carbon products, ordering, shipping, and certifications."
>
  <Navigation config={homeConfig} />

  <!-- Hero with background image -->
  <section class="section-lg relative overflow-hidden px-4 sm:px-6 lg:px-8">
    <Image
      src={faqHeroBg}
      alt=""
      widths={[800, 1200, 1920]}
      sizes="100vw"
      class="absolute inset-0 h-full w-full object-cover"
      loading="eager"
    />
    <div class="absolute inset-0 bg-gradient-to-br from-black/80 via-black/65 to-black/75"></div>
    <div class="relative mx-auto max-w-4xl text-center">
      <h1 class="scroll-fade-up mb-4 text-3xl font-medium text-white sm:text-4xl lg:text-5xl">
        FAQs
      </h1>
      <p class="scroll-fade-up mx-auto max-w-2xl text-base leading-relaxed text-white/85 sm:text-lg lg:text-xl">
        Quick answers to common questions about our products, ordering process, and quality standards
      </p>
    </div>
  </section>

  <!-- FAQ Content -->
  <section class="bg-white section-lg px-4 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-6xl">
      <div class="grid grid-cols-1 gap-12 lg:grid-cols-[240px_1fr]">
        <!-- Left: Sticky Nav -->
        <nav class="hidden lg:block">
          <div class="sticky top-24 space-y-3">
            {faqPageData.categories.map((category, ci) => (
              <a
                href={`#faq-cat-${ci}`}
                class="faq-nav-link flex items-center gap-3 whitespace-nowrap rounded-xl bg-white px-5 py-4 text-sm font-medium text-mono-dark shadow-sm transition-all duration-200 hover:-translate-y-0.5 hover:shadow-lg hover:text-mono-black"
              >
                <Icon name={category.icon} class="h-5 w-5 flex-shrink-0" />
                {category.title}
              </a>
            ))}
          </div>
        </nav>

        <!-- Right: All Categories -->
        <div class="space-y-16">
          {faqPageData.categories.map((category, ci) => (
            <div id={`faq-cat-${ci}`} class="scroll-mt-24">
              <h2 class="text-mono-heading mb-6 flex items-center gap-3 text-xl font-medium sm:text-2xl">
                <Icon name={category.icon} class="text-mono-black h-6 w-6 lg:hidden" />
                {category.title}
              </h2>
              <div class="divide-y divide-mono-lighter border-y border-mono-lighter">
                {category.items.map((item) => (
                  <div class="py-5">
                    <button
                      class="faq-button flex w-full cursor-pointer items-center justify-between text-left"
                      aria-expanded="false"
                    >
                      <span class="text-mono-heading pr-8 font-semibold">{item.question}</span>
                      <Icon name="heroicons:chevron-down" class="faq-icon text-mono-gray h-5 w-5 flex-shrink-0 transition-transform duration-200" />
                    </button>
                    <div class="faq-content text-mono-dark leading-relaxed">{item.answer}</div>
                  </div>
                ))}
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <PageCTA
    title="Still Have Questions?"
    description="Our engineers are ready to help you find the right activated carbon solution."
    buttonText="Talk to an Engineer"
    buttonHref="#inquiry"
    bgImage={faqCtaBg}
  />
  <Footer config={homeConfig} />
</BaseLayout>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const faqButtons = document.querySelectorAll('.faq-button');
    faqButtons.forEach((button) => {
      button.addEventListener('click', () => {
        const content = button.nextElementSibling;
        const isExpanded = button.getAttribute('aria-expanded') === 'true';
        button.setAttribute('aria-expanded', String(!isExpanded));
        content?.classList.toggle('active');
      });
    });
  });
</script>
